+  std::unordered_map<VariableSymbol, VariableDefinition::ValueType> values;
+  auto [resolved, success] = sdsc->symbolDefinitions_.tryComputeVar(value,
+                                                                    values);
+  if (success) return resolved;
+
+  auto tagIt = sdsc->inputSymbolsAndTags_.find(value);
+  if (tagIt == sdsc->inputSymbolsAndTags_.end()) return value;
+
+  static const std::string prefix = "explicit_lx_range_proto_bundle_const:";
+  const auto& tag = tagIt->second;
+  if (tag.rfind(prefix, 0) != 0) return value;
+
+  try {
+    return std::stoll(tag.substr(prefix.size()));
+  } catch (...) {
+    return value;
+  }
+}
