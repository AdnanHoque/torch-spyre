+namespace {
+
+SliceInfo buildExplicitLxRangeSlice(
+    const STCDPOpLx::ExplicitLxRangeEndpoint& endpoint, const LdsInfo* lds) {
+  SliceInfo slice;
+  for (const auto& size : endpoint.logicalSizes) {
+    const auto& dim = size.first;
+    auto start = endpoint.logicalStarts.find(dim);
+    DT_CHECK_MSG(start != endpoint.logicalStarts.end(),
+                 "explicit lx range missing logical start for dim " + dim);
+    DT_CHECK_MSG(size.second > 0,
+                 "explicit lx range logical size must be positive for dim " +
+                     dim);
+    slice.dimToStartCordinate[dim] = start->second;
+    slice.dimToSize_[dim] = size.second;
+    if (lds != nullptr && lds->dimToLayoutSize_.count(dim)) {
+      slice.bigDimToSize_[dim] = lds->dimToLayoutSize_.at(dim);
+    } else {
+      slice.bigDimToSize_[dim] = size.second;
+    }
+  }
+
+  slice.placement.setType(SenComponents::LX);
+  slice.placement.insertMemId(endpoint.core);
+  slice.placement.insertStAddr(endpoint.lxAddress);
+  return slice;
+}
+
+PieceInfo buildExplicitLxRangePiece(const SliceInfo& slice,
+                                    const std::string& key) {
+  PieceInfo piece;
+  piece.key_ = key;
+  piece.dimToStartCordinate = slice.dimToStartCordinate;
+  piece.dimToSize_ = slice.dimToSize_;
+  for (const auto& size : slice.dimToSize_) {
+    piece.validGap_[size.first].push_back({size.second, 0});
+  }
+  piece.placement[slice.placement.Type()] = slice.placement;
+  return piece;
+}
+
+void materializeExplicitLxRangeProto(STCDPOpLx* op, DataOpDsc& dataOpDsc) {
+  DT_CHECK_MSG(op != nullptr, "explicit lx range materialization needs op");
+  DT_CHECK_MSG(!op->explicitLxRangeMovements.empty(),
+               "explicit lx range materialization needs movements");
+  DT_CHECK_MSG(op->explicitLxRangeMovements.size() <= 4096,
+               "explicit lx range prototype supports at most 4096 movements");
+  LdsInfo* inputLds = op->inpLds;
+  LdsInfo* outputLds = op->outLds;
+  if (inputLds == nullptr || outputLds == nullptr) {
+    DT_CHECK_MSG(dataOpDsc.labeledDs_.size() >= 2,
+                 "explicit lx range data-op needs input and output LDS");
+    inputLds = &dataOpDsc.labeledDs_.at(0);
+    outputLds = &dataOpDsc.labeledDs_.at(1);
+  }
+
+  op->inpSP_.clear();
+  op->outSP_.clear();
+  op->dtTable_.clear();
+  op->coreIDtoDtKey_L3SU.clear();
+  op->coreIDtoDtKey_L3LU.clear();
+  op->coreIDtoDtKey_LX.clear();
+  inputLds->pieces_.clear();
+  outputLds->pieces_.clear();
+
+  for (size_t idx = 0; idx < op->explicitLxRangeMovements.size(); idx++) {
+    const auto& movement = op->explicitLxRangeMovements.at(idx);
+    DT_CHECK_MSG(movement.count > 0,
+                 "explicit lx range count must be positive");
+
+    const auto inputSlice = buildExplicitLxRangeSlice(movement.source, inputLds);
+    const auto outputSlice =
+        buildExplicitLxRangeSlice(movement.destination, outputLds);
+    op->inpSP_.push_back(inputSlice);
+    op->outSP_.push_back(outputSlice);
+
+    const auto pieceKey = "explicit_range_" + std::to_string(idx);
+    inputLds->pieces_[pieceKey] = buildExplicitLxRangePiece(inputSlice, pieceKey);
+    outputLds->pieces_[pieceKey] =
+        buildExplicitLxRangePiece(outputSlice, pieceKey);
+
+    transferInfo transfer;
+    transfer.pIDX = static_cast<int>(idx);
+    transfer.pMemID = movement.source.core;
+    transfer.cIDXs.push_back(static_cast<int>(idx));
+    transfer.cMemIDs.push_back(movement.destination.core);
+    transfer.minCMemID = movement.destination.core;
+    transfer.trVolume = movement.bytesPerMove;
+    transfer.numTransactions_ = movement.count;
+    transfer.useBurst = false;
+    op->dtTable_[static_cast<int>(idx)] = transfer;
+  }
+}
+
+void dumpExplicitLxRangeDiagnostics(STCDPOpLx* op, const DataOpDsc& dataOpDsc) {
+  const char* dumpPath =
+      std::getenv("DEEPTOOLS_EXPLICIT_LX_RANGE_PROTO_DUMP");
+  if (dumpPath == nullptr || dumpPath[0] == '\0') return;
+
+  std::ofstream out(dumpPath, std::ios::app);
+  DT_CHECK_MSG(out.is_open(),
+               "failed to open explicit lx range diagnostic dump");
+
+  out << "dataOpDsc: " << dataOpDsc.dscName_ << "\n";
+  out << "parsedRangeCount: " << op->explicitLxRangeMovements.size() << "\n";
+  for (const auto& movement : op->explicitLxRangeMovements) {
+    out << "range[" << movement.rangeIndex << "]"
+        << " moveIndex=" << movement.moveIndex
+        << " bytesPerMove=" << movement.bytesPerMove
+        << " count=" << movement.count
+        << " sourceStrideBytes=" << movement.sourceStrideBytes
+        << " destinationStrideBytes=" << movement.destinationStrideBytes
+        << " srcCore=" << movement.source.core
+        << " srcLx=" << movement.source.lxAddress
+        << " dstCore=" << movement.destination.core
+        << " dstLx=" << movement.destination.lxAddress << "\n";
+    out << "  logicalSizes";
+    for (const auto& size : movement.source.logicalSizes) {
+      out << " " << size.first << "=" << size.second;
+    }
+    out << "\n";
+  }
+
+  out << "dtTableCount: " << op->dtTable_.size() << "\n";
+  for (const auto& tableEntry : op->dtTable_) {
+    const auto& transfer = tableEntry.second;
+    out << "dt[" << tableEntry.first << "]"
+        << " pIDX=" << transfer.pIDX << " pMemID=" << transfer.pMemID
+        << " minCMemID=" << transfer.minCMemID
+        << " trVolume=" << transfer.trVolume
+        << " numTransactions=" << transfer.numTransactions_
+        << " useBurst=" << transfer.useBurst << " cIDXs=";
+    for (auto cidx : transfer.cIDXs) out << cidx << ",";
+    out << " cMemIDs=";
+    for (auto cmem : transfer.cMemIDs) out << cmem << ",";
+    out << "\n";
+  }
+
+  auto dumpCoreMap = [&](const char* name,
+                         const std::map<int, std::vector<int>>& coreMap) {
+    out << name << "\n";
+    for (const auto& coreEntry : coreMap) {
+      out << "  core " << coreEntry.first << ":";
+      for (auto dtKey : coreEntry.second) out << " " << dtKey;
+      out << "\n";
+    }
+  };
+  dumpCoreMap("coreIDtoDtKey_L3SU", op->coreIDtoDtKey_L3SU);
+  dumpCoreMap("coreIDtoDtKey_L3LU", op->coreIDtoDtKey_L3LU);
+  dumpCoreMap("coreIDtoDtKey_LX", op->coreIDtoDtKey_LX);
+  out << "---\n";
+}
+
