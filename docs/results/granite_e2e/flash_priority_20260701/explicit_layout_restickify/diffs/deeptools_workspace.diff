+}
+
+bool tryGetConstantIndexValue(mlir::Value value, int64_t& result) {
+  if (!value) return false;
+
+  auto* op = value.getDefiningOp();
+  if (op == nullptr) return false;
+
+  if (auto constOp = mlir::dyn_cast<mlir::arith::ConstantOp>(op)) {
+    if (auto intAttr = mlir::dyn_cast<mlir::IntegerAttr>(constOp.getValue())) {
+      result = intAttr.getInt();
+      return true;
+    }
+  }
+
+  if (auto constIndexOp = mlir::dyn_cast<mlir::arith::ConstantIndexOp>(op)) {
+    result = constIndexOp.value();
+    return true;
+  }
+
+  if (auto addOp = mlir::dyn_cast<mlir::arith::AddIOp>(op)) {
+    int64_t lhs = 0;
+    int64_t rhs = 0;
+    if (tryGetConstantIndexValue(addOp.getLhs(), lhs) &&
+        tryGetConstantIndexValue(addOp.getRhs(), rhs)) {
+      result = lhs + rhs;
+      return true;
+    }
+  }
+
+  if (auto subOp = mlir::dyn_cast<mlir::arith::SubIOp>(op)) {
+    int64_t lhs = 0;
+    int64_t rhs = 0;
+    if (tryGetConstantIndexValue(subOp.getLhs(), lhs) &&
+        tryGetConstantIndexValue(subOp.getRhs(), rhs)) {
+      result = lhs - rhs;
+      return true;
+    }
+  }
+
+  if (auto mulOp = mlir::dyn_cast<mlir::arith::MulIOp>(op)) {
+    int64_t lhs = 0;
+    int64_t rhs = 0;
+    if (tryGetConstantIndexValue(mulOp.getLhs(), lhs) &&
+        tryGetConstantIndexValue(mulOp.getRhs(), rhs)) {
+      result = lhs * rhs;
+      return true;
+    }
+  }
+
+  return false;
+}
+
+void materializeExplicitRangeConstantSymbols(dxp::SdscNode* sdscNode,
+                                             SuperDsc* sdsc) {
+  if (!explicitLxRangeProtoEnabledForDxp() || sdscNode == nullptr ||
+      sdsc == nullptr) {
+    return;
+  }
+
+  auto bundleOp = sdscNode->getBundleOp();
+  DT_CHECK(bundleOp);
+
+  const auto& symbolIds = bundleOp.getSymbolIds();
+  const auto& symbolDefs = bundleOp.getSymbolDefinitions();
+  DT_CHECK_MSG(symbolIds.size() == symbolDefs.size(),
+               "Number of symbol ids and definitions should match");
+
+  for (int i = 0; i < symbolIds.size(); i++) {
+    int64_t value = 0;
+    if (!tryGetConstantIndexValue(symbolDefs[i], value)) continue;
+
+    const auto sym = static_cast<VariableSymbol>(
+        mlir::cast<mlir::IntegerAttr>(symbolIds[i]).getInt());
+    sdsc->inputSymbolsAndTags_[sym] =
+        "explicit_lx_range_proto_bundle_const:" + std::to_string(value);
+  }
+}
+
