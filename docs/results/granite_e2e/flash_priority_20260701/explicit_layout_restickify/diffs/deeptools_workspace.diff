+namespace {
+
+bool explicitLxRangeProtoEnabled() {
+  const char* value = std::getenv("DEEPTOOLS_EXPLICIT_LX_RANGE_PROTO");
+  if (value == nullptr) return false;
+  std::string normalized(value);
+  return !(normalized.empty() || normalized == "0" || normalized == "false" ||
+           normalized == "FALSE");
+}
+
+int64_t jsonInt64(const json11::Json& value, const std::string& field) {
+  DT_CHECK_MSG(value.is_number(),
+               "explicit lx range field must be numeric: " + field);
+  return static_cast<int64_t>(value.number_value());
+}
+
+std::map<std::string, double> jsonNumberMap(const json11::Json& value,
+                                            const std::string& field) {
+  DT_CHECK_MSG(value.is_object(),
+               "explicit lx range field must be object: " + field);
+  std::map<std::string, double> result;
+  for (const auto& item : value.object_items()) {
+    DT_CHECK_MSG(item.second.is_number(),
+                 "explicit lx range logical field must be numeric: " +
+                     field + "." + item.first);
+    result[item.first] = item.second.number_value();
+  }
+  return result;
+}
+
+json11::Json objectField(const json11::Json& value, const std::string& field) {
+  DT_CHECK_MSG(value.is_object(),
+               "explicit lx range container must be object for field: " +
+                   field);
+  const auto& object = value.object_items();
+  auto it = object.find(field);
+  DT_CHECK_MSG(it != object.end(),
+               "explicit lx range missing required field: " + field);
+  return it->second;
+}
+
+int64_t lxAddressFromEndpoint(const json11::Json& endpoint,
+                              const std::string& prefix) {
+  const auto& object = endpoint.object_items();
+  auto lxAddress = object.find("lxAddress");
+  if (lxAddress != object.end()) {
+    return jsonInt64(lxAddress->second, prefix + ".lxAddress");
+  }
+
+  auto lxByteRange = object.find("lxByteRange");
+  DT_CHECK_MSG(lxByteRange != object.end(),
+               "explicit lx range endpoint missing lxAddress/lxByteRange: " +
+                   prefix);
+  return jsonInt64(objectField(lxByteRange->second, "start"),
+                   prefix + ".lxByteRange.start");
+}
+
+STCDPOpLx::ExplicitLxRangeEndpoint parseExplicitLxRangeEndpoint(
+    const json11::Json& endpoint, const std::string& prefix) {
+  DT_CHECK_MSG(endpoint.is_object(),
+               "explicit lx range endpoint must be object: " + prefix);
+  STCDPOpLx::ExplicitLxRangeEndpoint parsed;
+  parsed.core = jsonInt64(objectField(endpoint, "core"), prefix + ".core");
+  parsed.lxAddress = lxAddressFromEndpoint(endpoint, prefix);
+
+  auto logicalSlice = objectField(endpoint, "logicalSlice");
+  parsed.logicalStarts =
+      jsonNumberMap(objectField(logicalSlice, "starts"),
+                    prefix + ".logicalSlice.starts");
+  parsed.logicalSizes =
+      jsonNumberMap(objectField(logicalSlice, "sizes"),
+                    prefix + ".logicalSlice.sizes");
+  DT_CHECK_MSG(parsed.logicalStarts.size() == parsed.logicalSizes.size(),
+               "explicit lx range logical starts/sizes rank mismatch");
+  return parsed;
+}
+
+void importExplicitLxRangeProto(STCDPOpLx* op, const json11::Json& remap) {
+  DT_CHECK_MSG(op != nullptr, "explicit lx range import needs STCDPOpLx");
+  DT_CHECK_MSG(remap.is_object(), "rangedLxRemap must be an object");
+
+  const auto& remapObject = remap.object_items();
+  auto loweringIt = remapObject.find("lowering");
+  if (loweringIt != remapObject.end() && loweringIt->second.is_object()) {
+    const auto& lowering = loweringIt->second.object_items();
+    auto unitsIt = lowering.find("addressUnits");
+    if (unitsIt != lowering.end()) {
+      DT_CHECK_MSG(unitsIt->second.string_value() == "bytes",
+                   "explicit lx range prototype only accepts byte addresses");
+    }
+  }
+
+  auto rangesIt = remapObject.find("movementRanges");
+  if (rangesIt == remapObject.end()) {
+    rangesIt = remapObject.find("movementRanges_excerpt");
+  }
+  DT_CHECK_MSG(rangesIt != remapObject.end(),
+               "rangedLxRemap missing movementRanges");
+  DT_CHECK_MSG(rangesIt->second.is_array(),
+               "rangedLxRemap movementRanges must be an array");
+
+  op->explicitLxRangeProtoImported = true;
+  op->explicitLxRangeMovements.clear();
+
+  const auto& ranges = rangesIt->second.array_items();
+  DT_CHECK_MSG(!ranges.empty(),
+               "explicit lx range prototype needs at least one range");
+  DT_CHECK_MSG(ranges.size() <= 4096,
+               "explicit lx range prototype supports at most 4096 ranges");
+  for (size_t rangeIdx = 0; rangeIdx < ranges.size(); rangeIdx++) {
+    const auto& range = ranges.at(rangeIdx);
+    STCDPOpLx::ExplicitLxRangeMovement movement;
+    movement.rangeIndex = static_cast<int>(rangeIdx);
+    movement.moveIndex = static_cast<int>(rangeIdx);
+    const auto& rangeObject = range.object_items();
+    auto maybeSetInt = [&](const char* key, int* target) {
+      auto it = rangeObject.find(key);
+      if (it != rangeObject.end()) *target = jsonInt64(it->second, key);
+    };
+    auto maybeSetInt64 = [&](const char* key, int64_t* target) {
+      auto it = rangeObject.find(key);
+      if (it != rangeObject.end()) *target = jsonInt64(it->second, key);
+    };
+
+    maybeSetInt("rangeIndex", &movement.rangeIndex);
+    maybeSetInt("moveIndex", &movement.moveIndex);
+    maybeSetInt("count", &movement.count);
+    maybeSetInt64("bytesPerMove", &movement.bytesPerMove);
+    maybeSetInt64("sourceStrideBytes", &movement.sourceStrideBytes);
+    maybeSetInt64("destinationStrideBytes", &movement.destinationStrideBytes);
+
+    DT_CHECK_MSG(movement.count > 0,
+                 "explicit lx range count must be positive");
+    DT_CHECK_MSG(movement.bytesPerMove > 0,
+                 "explicit lx range bytesPerMove must be positive");
+    DT_CHECK_MSG(movement.count == 1 ||
+                     movement.destinationStrideBytes >= movement.bytesPerMove,
+                 "explicit lx range destination stride must cover bytesPerMove");
+    movement.source =
+        parseExplicitLxRangeEndpoint(objectField(range, "source"), "source");
+    movement.destination = parseExplicitLxRangeEndpoint(
+        objectField(range, "destination"), "destination");
+    DT_CHECK_MSG(movement.source.logicalSizes ==
+                     movement.destination.logicalSizes,
+                 "explicit lx range source/destination sizes must match");
+    op->explicitLxRangeMovements.push_back(std::move(movement));
+  }
+}
