+static void checkStagedSubStickPrototypeFeasible(
+    const SuperDsc* sdsc, DesignSpaceConfig& dldsc, const LabeledDsInfo& lds,
+    const std::map<PrimaryDimTypes, int>& producerSliceCounts) {
+  if (!isEnvFlagEnabled("DXP_LX_RELAYOUT_STAGED_SUBSTICK")) {
+    return;
+  }
+
+  const auto& refDsInfo = dldsc.primaryDsInfo_.at(lds.dsType_);
+  DT_CHECK(refDsInfo.stickDimOrder_.size() == refDsInfo.stickSize_.size());
+
+  bool hasSubStickProducerSlice = false;
+  std::ostringstream subStickDims;
+  for (int idx = 0; idx < refDsInfo.stickDimOrder_.size(); idx++) {
+    const auto pDim = refDsInfo.stickDimOrder_.at(idx);
+    const std::string dimName = primaryDimName(dldsc, pDim);
+    const int sliceCount = producerSliceCounts.count(pDim)
+                               ? producerSliceCounts.at(pDim)
+                               : 1;
+    DT_CHECK(sliceCount > 0);
+    const double extent = dldsc.N_.paramNameToVal(dimName);
+    const double producerSliceSize = extent / sliceCount;
+    const int stickSize = refDsInfo.stickSize_.at(idx);
+    if (producerSliceSize < stickSize) {
+      hasSubStickProducerSlice = true;
+      subStickDims << " dim=" << dimName << " extent=" << extent
+                   << " producerSlices=" << sliceCount
+                   << " producerSliceSize=" << producerSliceSize
+                   << " stickSize=" << stickSize;
+    }
+  }
+
+  if (!hasSubStickProducerSlice) {
+    return;
+  }
+
+  if (isEnvFlagEnabled("DXP_STCDP_SUBSTICK_RANGES")) {
+    std::cerr << "[relayout] staged-substick range experiment sdsc="
+              << sdsc->name_ << " lds=" << lds.dsName_
+              << subStickDims.str() << std::endl;
+    return;
+  }
+
+  DT_CHECK_MSG(
+      false,
+      "DXP_LX_RELAYOUT_STAGED_SUBSTICK requested for " + sdsc->name_ +
+          ":" + lds.dsName_ +
+          ", but the current DataOpDsc composition cannot safely stage "
+          "producer sub-stick LX slices before STCDP." +
+          subStickDims.str() +
+          ". Missing API/metadata: STCDPOpLx PieceInfo/SliceInfo has no "
+          "per-memId intra-stick offset/range and insertSubPieces collapses "
+          "multi-memId input placement to the first producer core; "
+          "ReStickifyOpLx gap insertion is LDS-level, not per producer core "
+          "or per movement piece, so it cannot pad distinct 16-wide "
+          "producer quarters into 64-wide whole-stick staging; and "
+          "SdscRelayoutInsertion has no scheduling contract to insert a "
+          "producer-local staging data-op before ring movement and retarget "
+          "the consumer allocation to a post-ring local extract without "
+          "losing producer slice offsets. Set DXP_STCDP_SUBSTICK_RANGES=1 "
+          "to run the experimental internal-range prototype.");
+}
