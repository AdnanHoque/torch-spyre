+TEST_F(stcdpLibtest, lxLe128LocalSubStickAssembleRoundTrip) {
+  SenPcfg pcfg;
+  pcfg.dtFormat = DataFormats::SEN169_FP16;
+  auto* transfer = static_cast<SenPcfgLE128BTransferNode*>(
+      pcfg.createPcfgNode(SenPcfgNode::Type::LE128BTRANSFER));
+  transfer->name = "local-lx-assemble-four-quarters";
+  transfer->srcDest = {SenComponents::LX, SenComponents::LX};
+  transfer->isPartStick = true;
+  transfer->wordLength = 2;
+  transfer->stickSize = 64;
+  transfer->dimLayoutOrder = {"k"};
+  transfer->myBigDimSize["k"] = 128;
+  transfer->myLitDimSize["k"] = 1;
+  transfer->setSrcStAddr(0);
+  transfer->setDestStAddr(4096);
+  pcfg.srcNode = transfer;
+
+  constexpr std::array<int, 4> srcOffsets = {0, 32, 64, 96};
+  constexpr std::array<int, 4> dstOffsets = {32, 64, 96, 0};
+  for (int idx = 0; idx < static_cast<int>(srcOffsets.size()); idx++) {
+    transfer->byteOffsetTr.emplace_back(32, srcOffsets.at(idx),
+                                        dstOffsets.at(idx), true, true);
+  }
+
+  const std::string json = pcfg.exportJsonStr();
+  EXPECT_NE(json.find("\"byteOffsetTr\""), std::string::npos);
+  EXPECT_NE(json.find("\"numBytes\" : 32"), std::string::npos);
+  EXPECT_NE(json.find("\"srcByteOffset\" : 0"), std::string::npos);
+  EXPECT_NE(json.find("\"dstByteOffset\" : 96"), std::string::npos);
+
+  SenPcfg roundTrip;
+  ASSERT_TRUE(roundTrip.importJsonStr(json));
+  ASSERT_EQ(roundTrip.pcfgNodes.size(), 1);
+  auto* rtTransfer = dynamic_cast<SenPcfgLE128BTransferNode*>(
+      roundTrip.pcfgNodes.front());
+  ASSERT_NE(rtTransfer, nullptr);
+  EXPECT_TRUE(rtTransfer->isPartStick);
+  ASSERT_EQ(rtTransfer->byteOffsetTr.size(), srcOffsets.size());
+  for (int idx = 0; idx < static_cast<int>(srcOffsets.size()); idx++) {
+    EXPECT_EQ(rtTransfer->byteOffsetTr.at(idx).bytesToTransfer, 32);
+    EXPECT_EQ(rtTransfer->byteOffsetTr.at(idx).srcByteOffset,
+              srcOffsets.at(idx));
+    EXPECT_EQ(rtTransfer->byteOffsetTr.at(idx).dstByteOffset,
+              dstOffsets.at(idx));
+    EXPECT_TRUE(rtTransfer->byteOffsetTr.at(idx).addBaseAddr);
+    EXPECT_TRUE(rtTransfer->byteOffsetTr.at(idx).addSrcBaseAddr);
+    EXPECT_TRUE(rtTransfer->byteOffsetTr.at(idx).addDstBaseAddr);
+    EXPECT_TRUE(rtTransfer->byteOffsetTr.at(idx).hasIndependentSrcDstOffsets());
+  }
+}
