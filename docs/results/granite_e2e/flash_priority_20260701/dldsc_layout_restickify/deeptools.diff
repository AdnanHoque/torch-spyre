+static bool emitCfgDiag() {
+  static bool enabled = std::getenv("DXP_DEBUG_SENTIENT_CFG") != nullptr;
+  return enabled;
+}
+
+static std::string fingerprintValue(Value value) {
+  if (isa<BlockArgument>(value)) return "block-arg";
+  Operation *def_op = value.getDefiningOp();
+  if (!def_op) return "unknown";
+  std::string result = def_op->getName().getStringRef().str();
+  if (auto const_op = dyn_cast<sentient::ConstantOp>(def_op))
+    result += ":" + std::to_string(const_op.getValue());
+  return result;
+}
+
+static void emitUnitCfgDiag(StringRef pass_name, dataflow::ProgramUnitOp unit_op,
+                            int merge_count = -1) {
+  if (!emitCfgDiag()) return;
+  int64_t if_count = 0;
+  int64_t result_if_count = 0;
+  int64_t zero_result_if_count = 0;
+  int64_t top_level_if_count = 0;
+  int64_t max_depth = 0;
+  std::map<Block *, int64_t> ifs_per_block;
+  std::map<std::string, int64_t> condition_groups;
+
+  unit_op.walk<WalkOrder::PreOrder>([&](sentient::IfOp if_op) {
+    ++if_count;
+    if (if_op->getNumResults() == 0)
+      ++zero_result_if_count;
+    else
+      ++result_if_count;
+
+    int64_t depth = 0;
+    for (Operation *parent = if_op->getParentOp(); parent;
+         parent = parent->getParentOp()) {
+      if (isa<dataflow::ProgramUnitOp>(parent)) break;
+      if (isa<sentient::IfOp>(parent)) ++depth;
+    }
+    if (depth == 0) ++top_level_if_count;
+    max_depth = std::max(max_depth, depth + 1);
+
+    Block *block = if_op->getBlock();
+    ++ifs_per_block[block];
+    std::string key = std::to_string(reinterpret_cast<uintptr_t>(block)) + "|" +
+                      std::to_string(static_cast<int>(if_op.getPredicate())) +
+                      "|" + fingerprintValue(if_op.getLhs()) + "|" +
+                      fingerprintValue(if_op.getRhs());
+    ++condition_groups[key];
+  });
+
+  int64_t max_block_siblings = 0;
+  int64_t blocks_with_sibling_ifs = 0;
+  for (const auto &entry : ifs_per_block) {
+    max_block_siblings = std::max(max_block_siblings, entry.second);
+    if (entry.second > 1) ++blocks_with_sibling_ifs;
+  }
+  int64_t max_same_condition_siblings = 0;
+  int64_t repeated_condition_groups = 0;
+  for (const auto &entry : condition_groups) {
+    max_same_condition_siblings =
+        std::max(max_same_condition_siblings, entry.second);
+    if (entry.second > 1) ++repeated_condition_groups;
+  }
+
+  llvm::errs() << "[DXP_CFG_DIAG] pass=" << pass_name
+               << " unit_line=" << dcc::utils::getLocation(unit_op).getLine()
+               << " ifs=" << if_count << " result_ifs=" << result_if_count
+               << " zero_result_ifs=" << zero_result_if_count
+               << " top_level_ifs=" << top_level_if_count
+               << " max_depth=" << max_depth
+               << " blocks_with_sibling_ifs=" << blocks_with_sibling_ifs
+               << " max_block_siblings=" << max_block_siblings
+               << " repeated_condition_groups=" << repeated_condition_groups
+               << " max_same_condition_siblings=" << max_same_condition_siblings;
+  if (merge_count >= 0) llvm::errs() << " merges=" << merge_count;
+  llvm::errs() << "\n";
+}
+
