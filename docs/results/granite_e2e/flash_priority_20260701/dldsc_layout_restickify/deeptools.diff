+TEST_F(stcdpLibtest, lxLe128LocalAssembleAroundWholeStickRingRoundTrip) {
+  SenPcfg pcfg;
+  pcfg.dtFormat = DataFormats::SEN169_FP16;
+
+  auto* assemble = static_cast<SenPcfgLE128BTransferNode*>(
+      pcfg.createPcfgNode(SenPcfgNode::Type::LE128BTRANSFER));
+  assemble->name = "c0-L3SU-localAssembleBeforeRing-0-99";
+  assemble->srcDest = {SenComponents::LX, SenComponents::LX};
+  assemble->isPartStick = true;
+  assemble->wordLength = 2;
+  assemble->stickSize = 64;
+  assemble->dimLayoutOrder = {"k"};
+  assemble->myBigDimSize["k"] = 1;
+  assemble->myLitDimSize["k"] = 1;
+  assemble->setSrcStAddr(1024);
+  assemble->setDestStAddr(2048);
+
+  auto* ring = static_cast<SenPcfgRingDtNode*>(
+      pcfg.createPcfgNode(SenPcfgNode::Type::RINGDATATRANSFER));
+  ring->name = "c0-L3SU-ringDT-LX-RING-0-99";
+  ring->srcDest = {SenComponents::LX, SenComponents::RING};
+  ring->coreletId = -1;
+  ring->dtInfo = nullptr;
+  ring->dsInfo = nullptr;
+  ring->dimLayoutOrder = {"k"};
+  ring->myBigDimSize["k"] = 1;
+  ring->myLitDimSize["k"] = 1;
+  ring->setSrcStAddr(2048);
+  ring->coreIdForRing = {1};
+
+  assemble->next.push_back(ring);
+  ring->prev.push_back(assemble);
+  pcfg.srcNode = assemble;
+
+  constexpr std::array<int, 4> srcOffsets = {0, 32, 64, 96};
+  constexpr std::array<int, 4> dstOffsets = {96, 0, 32, 64};
+  for (int idx = 0; idx < static_cast<int>(srcOffsets.size()); idx++) {
+    assemble->byteOffsetTr.emplace_back(32, srcOffsets.at(idx),
+                                        dstOffsets.at(idx), true, true);
+  }
+
+  const std::string json = pcfg.exportJsonStr();
+  EXPECT_NE(json.find("\"type\" : \"le128btransfer\""), std::string::npos);
+  EXPECT_NE(json.find("\"type\" : \"ringdatatransfer\""), std::string::npos);
+  EXPECT_NE(json.find("localAssembleBeforeRing"), std::string::npos);
+  EXPECT_NE(json.find("ringDT-LX-RING"), std::string::npos);
+  EXPECT_NE(json.find("\"srcByteOffset\" : 96"), std::string::npos);
+  EXPECT_NE(json.find("\"dstByteOffset\" : 96"), std::string::npos);
+
+  SenPcfg roundTrip;
+  ASSERT_TRUE(roundTrip.importJsonStr(json));
+  int le128Count = 0;
+  int ringCount = 0;
+  for (auto* node : roundTrip.pcfgNodes) {
+    if (node->type == SenPcfgNode::Type::LE128BTRANSFER) {
+      le128Count++;
+      const auto* le128 = dynamic_cast<const SenPcfgLE128BTransferNode*>(node);
+      ASSERT_NE(le128, nullptr);
+      ASSERT_EQ(le128->byteOffsetTr.size(), srcOffsets.size());
+      EXPECT_EQ(le128->byteOffsetTr.at(0).srcByteOffset, 0);
+      EXPECT_EQ(le128->byteOffsetTr.at(0).dstByteOffset, 96);
+    } else if (node->type == SenPcfgNode::Type::RINGDATATRANSFER) {
+      ringCount++;
+    }
+  }
+  EXPECT_EQ(le128Count, 1);
+  EXPECT_EQ(ringCount, 1);
+}
