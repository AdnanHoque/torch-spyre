 }
 
+std::uint64_t splitForDim(const Json &dims, const std::string &dim) {
+  if (!dims.is_object()) return 0;
+  const int split = dims[dim].int_value();
+  return split > 0 ? static_cast<std::uint64_t>(split) : 0;
+}
+
+std::vector<std::string> stringArray(const Json &json) {
+  std::vector<std::string> values;
+  if (!json.is_array()) return values;
+  for (const auto &value : json.array_items()) {
+    if (!value.is_string()) return {};
+    values.push_back(value.string_value());
+  }
+  return values;
+}
+
+bool optionalStringIs(const Json &json, const std::string &key,
+                      const std::string &expected) {
+  return json[key].is_null() ||
+         (json[key].is_string() && json[key].string_value() == expected);
+}
+
+bool allRestickifyDimsRenamedToConsumer(const Json &json,
+                                        std::string *reason) {
+  const auto restickifyDims = stringArray(
+      json["restickify_kernel_layout"]["layoutDimOrder_"]);
+  const auto consumerDims =
+      stringArray(json["consumer_kernel_layout"]["layoutDimOrder_"]);
+  if (restickifyDims.empty() || consumerDims.empty()) {
+    *reason = "missing restickify or consumer layout dimensions";
+    return false;
+  }
+
+  const std::set<std::string> consumerDimSet(consumerDims.begin(),
+                                             consumerDims.end());
+  const Json &rename = json["dimension_rename"];
+  if (!rename.is_object()) {
+    *reason = "missing dimension_rename";
+    return false;
+  }
+
+  for (const auto &dim : restickifyDims) {
+    const std::string renameKey = "restickify." + dim;
+    const Json &renamed = rename[renameKey];
+    if (!renamed.is_string() || renamed.string_value().empty()) {
+      *reason = "missing rename for " + renameKey;
+      return false;
+    }
+
+    const std::string consumerPrefix = "batchmatmul.";
+    const std::string renamedValue = renamed.string_value();
+    if (renamedValue.rfind(consumerPrefix, 0) != 0) {
+      *reason = renameKey + " must rename to a batchmatmul dimension";
+      return false;
+    }
+
+    const std::string consumerDim = renamedValue.substr(consumerPrefix.size());
+    if (consumerDimSet.count(consumerDim) == 0) {
+      *reason = renamedValue + " is not in consumer_kernel_layout";
+      return false;
+    }
+  }
+
+  return true;
+}
