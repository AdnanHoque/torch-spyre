+LayoutAllgatherRestickifyMovementPlan
+synthesizeLayoutAllgatherRestickifyMovementPlan(
+    const std::string &jsonString) {
+  const auto check = checkLayoutAllgatherRestickifyContract(jsonString);
+  if (!check.ok) {
+    return movementFail("contract check failed: " + check.reason);
+  }
+
+  std::string err;
+  const Json json = Json::parse(jsonString, err);
+  if (!err.empty() || !json.is_object()) {
+    return movementFail("invalid json after contract check");
+  }
+
+  if (!optionalStringIs(json, "communication_pattern",
+                        "layout_allgather_restickify")) {
+    return movementFail(
+        "communication_pattern must be layout_allgather_restickify");
+  }
+  if (json["producer_op"].string_value() != "mul") {
+    return movementFail("producer_op must be mul");
+  }
+  if (json["restickify_op"].string_value() != "ReStickifyOpHBM") {
+    return movementFail("restickify_op must be ReStickifyOpHBM");
+  }
+  if (json["consumer_op"].string_value() != "batchmatmul") {
+    return movementFail("consumer_op must be batchmatmul");
+  }
+  if (check.sourceCoreCount != check.restickifyCoreCount) {
+    return movementFail(
+        "producer/restickify core counts must match for on-chip restickify");
+  }
+
+  const Json &restickifySplits = json["restickify_work_slice_dims"];
+  const Json &consumerSplits = json["consumer_work_slice_dims"];
+  const std::uint64_t groupCount = splitForDim(restickifySplits, "mb");
+  const std::uint64_t consumerGroupCount = splitForDim(consumerSplits, "x");
+  const std::uint64_t producerChunksPerGroup =
+      splitForDim(restickifySplits, "x");
+  const std::uint64_t consumerCoresPerGroup = splitForDim(consumerSplits, "mb");
+  if (groupCount == 0 || consumerGroupCount == 0 ||
+      producerChunksPerGroup == 0 || consumerCoresPerGroup == 0) {
+    return movementFail(
+        "restickify mb/x and consumer x/mb splits must be non-zero");
+  }
+  if (groupCount != consumerGroupCount) {
+    return movementFail("restickify mb split must match batchmatmul x split");
+  }
+  if (check.restickifyCoreCount != groupCount * producerChunksPerGroup) {
+    return movementFail(
+        "restickify core count must equal mb groups times x chunks");
+  }
+  if (check.consumerCoreCount != groupCount * consumerCoresPerGroup) {
+    return movementFail(
+        "consumer core count must equal x groups times mb consumers");
+  }
+  if (splitForDim(consumerSplits, "out") != 1 ||
+      splitForDim(consumerSplits, "in") != 1) {
+    return movementFail("only unsplit batchmatmul out/in are supported");
+  }
+
+  std::string renameReason;
+  if (!allRestickifyDimsRenamedToConsumer(json, &renameReason)) {
+    return movementFail("dimension_rename cannot drive movement: " +
+                        renameReason);
+  }
+
+  LayoutAllgatherRestickifyMovementPlan plan;
+  plan.ok = true;
+  plan.reason = "ok";
+  plan.communicationClass = check.communicationClass;
+  plan.movementPattern = check.kind;
+  plan.restickifyOp = "ReStickifyOpLx";
+  plan.consumerOperandDsType = "KERNEL";
+  plan.sourceCoreCount = check.sourceCoreCount;
+  plan.restickifyCoreCount = check.restickifyCoreCount;
+  plan.consumerCoreCount = check.consumerCoreCount;
+  plan.groupCount = groupCount;
+  plan.producerChunksPerGroup = producerChunksPerGroup;
+  plan.consumerCoresPerGroup = consumerCoresPerGroup;
+  plan.replicationFactor = consumerCoresPerGroup;
+  plan.logicalTransferCount =
+      groupCount * producerChunksPerGroup * consumerCoresPerGroup;
+  plan.stages = {"restickify_layout_on_chip", "grouped_all_gather",
+                 "bind_bmm_kernel_operand"};
+  return plan;
+}
+
 }  // namespace deeptools
