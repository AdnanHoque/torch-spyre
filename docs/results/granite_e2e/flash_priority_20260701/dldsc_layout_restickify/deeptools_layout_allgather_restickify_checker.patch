+/************************************************************
+ * IBM Confidential
+ * (C) Copyright IBM Corp. 2026
+ ************************************************************/
+
+#include <gtest/gtest.h>
+
+#include <string>
+
+#include "util/LayoutAllgatherRestickify.h"
+
+namespace {
+
+std::string validFlashContract() {
+  return R"json({
+    "kind": "layout_allgather_restickify",
+    "communication_class": "all_gather",
+    "communication_pattern": "layout_allgather_restickify",
+    "producer_op": "mul",
+    "restickify_op": "ReStickifyOpHBM",
+    "consumer_op": "batchmatmul",
+    "requires_staged_realization": true,
+    "producer_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+    "restickify_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+    "consumer_work_slice_dims": {"x": 4, "mb": 8, "out": 1, "in": 1},
+    "producer_layout": {
+      "layoutDimOrder_": ["out", "x", "mb"],
+      "stickDimOrder_": ["out"]
+    },
+    "restickify_kernel_layout": {
+      "layoutDimOrder_": ["x", "out", "mb"],
+      "stickDimOrder_": ["x"]
+    },
+    "consumer_kernel_layout": {
+      "layoutDimOrder_": ["out", "in", "x"],
+      "stickDimOrder_": ["out"]
+    },
+    "dimension_rename": {
+      "restickify.mb": "batchmatmul.x",
+      "restickify.out": "batchmatmul.in",
+      "restickify.x": "batchmatmul.out"
+    },
+    "realized": false
+  })json";
+}
+
+}  // namespace
+
+TEST(LayoutAllgatherRestickify, acceptsCompleteFlashContract) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      validFlashContract());
+
+  EXPECT_TRUE(result.ok) << result.reason;
+  EXPECT_EQ(result.kind, "layout_allgather_restickify");
+  EXPECT_EQ(result.communicationClass, "all_gather");
+  EXPECT_TRUE(result.requiresStagedRealization);
+  EXPECT_EQ(result.sourceCoreCount, 32);
+  EXPECT_EQ(result.restickifyCoreCount, 32);
+  EXPECT_EQ(result.consumerCoreCount, 32);
+}
+
+TEST(LayoutAllgatherRestickify, rejectsScatterMetadata) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      R"json({
+        "kind": "layout_allgather_restickify",
+        "communication_class": "scatter",
+        "requires_staged_realization": true,
+        "producer_op": "mul",
+        "restickify_op": "ReStickifyOpHBM",
+        "consumer_op": "batchmatmul"
+      })json");
+
+  EXPECT_FALSE(result.ok);
+  EXPECT_EQ(result.reason, "communication_class must be all_gather");
+}
+
+TEST(LayoutAllgatherRestickify, rejectsMissingLayoutRename) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      R"json({
+        "kind": "layout_allgather_restickify",
+        "communication_class": "all_gather",
+        "requires_staged_realization": true,
+        "producer_op": "mul",
+        "restickify_op": "ReStickifyOpHBM",
+        "consumer_op": "batchmatmul",
+        "producer_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+        "restickify_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+        "consumer_work_slice_dims": {"x": 4, "mb": 8, "out": 1, "in": 1},
+        "producer_layout": {"layoutDimOrder_": ["out", "x", "mb"], "stickDimOrder_": ["out"]},
+        "restickify_kernel_layout": {"layoutDimOrder_": ["x", "out", "mb"], "stickDimOrder_": ["x"]},
+        "consumer_kernel_layout": {"layoutDimOrder_": ["out", "in", "x"], "stickDimOrder_": ["out"]}
+      })json");
+
+  EXPECT_FALSE(result.ok);
+  EXPECT_EQ(result.reason, "missing dimension_rename");
+}
+
+TEST(LayoutAllgatherRestickify, rejectsZeroWidthSplit) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      R"json({
+        "kind": "layout_allgather_restickify",
+        "communication_class": "all_gather",
+        "requires_staged_realization": true,
+        "producer_op": "mul",
+        "restickify_op": "ReStickifyOpHBM",
+        "consumer_op": "batchmatmul",
+        "producer_work_slice_dims": {"mb": 4, "x": 0, "out": 1},
+        "restickify_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+        "consumer_work_slice_dims": {"x": 4, "mb": 8, "out": 1, "in": 1},
+        "producer_layout": {"layoutDimOrder_": ["out", "x", "mb"], "stickDimOrder_": ["out"]},
+        "restickify_kernel_layout": {"layoutDimOrder_": ["x", "out", "mb"], "stickDimOrder_": ["x"]},
+        "consumer_kernel_layout": {"layoutDimOrder_": ["out", "in", "x"], "stickDimOrder_": ["out"]},
+        "dimension_rename": {"restickify.mb": "batchmatmul.x"}
+      })json");
+
+  EXPECT_FALSE(result.ok);
+  EXPECT_EQ(result.reason, "producer_work_slice_dims product must be non-zero");
+}
