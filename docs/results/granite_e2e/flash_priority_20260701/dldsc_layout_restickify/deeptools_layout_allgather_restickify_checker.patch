index 0000000..7968e10
--- /dev/null
+++ b/util/LayoutAllgatherRestickify.cpp
@@ -0,0 +1,138 @@
+/************************************************************
+ * IBM Confidential
+ * (C) Copyright IBM Corp. 2026
+ ************************************************************/
+
+#include "util/LayoutAllgatherRestickify.h"
+
+#include <external/json11/json11.hpp>
+
+#include <cstdint>
+#include <string>
+
+namespace {
+
+using json11::Json;
+
+bool hasNonEmptyString(const Json &json, const std::string &key) {
+  return json[key].is_string() && !json[key].string_value().empty();
+}
+
+bool hasNonEmptyObject(const Json &json, const std::string &key) {
+  return json[key].is_object() && !json[key].object_items().empty();
+}
+
+bool hasNonEmptyArray(const Json &json, const std::string &key) {
+  return json[key].is_array() && !json[key].array_items().empty();
+}
+
+bool hasLayoutContract(const Json &json, const std::string &key) {
+  const Json &layout = json[key];
+  return layout.is_object() && hasNonEmptyArray(layout, "layoutDimOrder_") &&
+         hasNonEmptyArray(layout, "stickDimOrder_");
+}
+
+std::uint64_t splitProduct(const Json &dims) {
+  if (!dims.is_object()) return 0;
+
+  std::uint64_t product = 1;
+  bool sawDim = false;
+  for (const auto &[_, value] : dims.object_items()) {
+    const int dim = value.int_value();
+    if (dim <= 0) return 0;
+    product *= static_cast<std::uint64_t>(dim);
+    sawDim = true;
+  }
+  return sawDim ? product : 0;
+}
+
+deeptools::LayoutAllgatherRestickifyCheckResult fail(
+    const std::string &reason) {
+  deeptools::LayoutAllgatherRestickifyCheckResult result;
+  result.reason = reason;
+  return result;
+}
+
+}  // namespace
+
+namespace deeptools {
+
+LayoutAllgatherRestickifyCheckResult checkLayoutAllgatherRestickifyContract(
+    const std::string &jsonString) {
+  std::string err;
+  const Json json = Json::parse(jsonString, err);
+  if (!err.empty()) {
+    return fail("invalid json: " + err);
+  }
+  if (!json.is_object()) {
+    return fail("contract must be a json object");
+  }
+
+  LayoutAllgatherRestickifyCheckResult result;
+  result.kind = json["kind"].string_value();
+  result.communicationClass = json["communication_class"].string_value();
+  result.requiresStagedRealization =
+      json["requires_staged_realization"].bool_value();
+
+  if (result.kind != "layout_allgather_restickify") {
+    return fail("kind must be layout_allgather_restickify");
+  }
+  if (result.communicationClass != "all_gather") {
+    return fail("communication_class must be all_gather");
+  }
+  if (!result.requiresStagedRealization) {
+    return fail("requires_staged_realization must be true");
+  }
+
+  if (!hasNonEmptyString(json, "producer_op")) {
+    return fail("missing producer_op");
+  }
+  if (!hasNonEmptyString(json, "restickify_op")) {
+    return fail("missing restickify_op");
+  }
+  if (!hasNonEmptyString(json, "consumer_op")) {
+    return fail("missing consumer_op");
+  }
+
+  if (!hasLayoutContract(json, "producer_layout")) {
+    return fail("missing producer_layout layout/stick dim order");
+  }
+  if (!hasLayoutContract(json, "restickify_kernel_layout")) {
+    return fail("missing restickify_kernel_layout layout/stick dim order");
+  }
+  if (!hasLayoutContract(json, "consumer_kernel_layout")) {
+    return fail("missing consumer_kernel_layout layout/stick dim order");
+  }
+  if (!hasNonEmptyObject(json, "dimension_rename")) {
+    return fail("missing dimension_rename");
+  }
+
+  if (!hasNonEmptyObject(json, "producer_work_slice_dims")) {
+    return fail("missing producer_work_slice_dims");
+  }
+  if (!hasNonEmptyObject(json, "restickify_work_slice_dims")) {
+    return fail("missing restickify_work_slice_dims");
+  }
+  if (!hasNonEmptyObject(json, "consumer_work_slice_dims")) {
+    return fail("missing consumer_work_slice_dims");
+  }
+
+  result.sourceCoreCount = splitProduct(json["producer_work_slice_dims"]);
+  result.restickifyCoreCount = splitProduct(json["restickify_work_slice_dims"]);
+  result.consumerCoreCount = splitProduct(json["consumer_work_slice_dims"]);
+  if (result.sourceCoreCount == 0) {
+    return fail("producer_work_slice_dims product must be non-zero");
+  }
+  if (result.restickifyCoreCount == 0) {
+    return fail("restickify_work_slice_dims product must be non-zero");
+  }
+  if (result.consumerCoreCount == 0) {
+    return fail("consumer_work_slice_dims product must be non-zero");
+  }
+
+  result.ok = true;
+  result.reason = "ok";
+  return result;
+}
+
+}  // namespace deeptools
diff --git a/util/LayoutAllgatherRestickify.h b/util/LayoutAllgatherRestickify.h
