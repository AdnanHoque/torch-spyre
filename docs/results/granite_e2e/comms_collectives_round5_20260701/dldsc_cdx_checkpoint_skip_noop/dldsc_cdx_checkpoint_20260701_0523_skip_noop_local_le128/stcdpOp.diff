+static int positiveRemainder(int value, int modulus) {
+  DT_CHECK(modulus > 0);
+  int result = value % modulus;
+  return result < 0 ? result + modulus : result;
+}
+
+static bool hasExplicitSubStickRangeForSide(const STCDPOpLx* op,
+                                            const transferInfo& dtEntry,
+                                            const SliceInfo& subPiece,
+                                            const std::string& dimName,
+                                            bool producerSide) {
+  if (!op->enableSubStickRanges) return false;
+  if (dtEntry.subStickRanges.empty()) return false;
+  DT_CHECK(subPiece.dimToSize_.count(dimName));
+  const int elementCount = subPiece.dimToSize_.at(dimName);
+  for (const auto& range : dtEntry.subStickRanges) {
+    if (range.transferDim != dimName) continue;
+    if (range.elementCount != elementCount) continue;
+    if (producerSide) {
+      if (range.producerMemId == dtEntry.pMemID) return true;
+    } else {
+      for (const auto consumerMemId : subPiece.placement.getMemId()) {
+        if (range.consumerMemId == consumerMemId) return true;
+      }
+    }
+  }
+  return false;
+}
+
+static void appendSubStickRangesForOverlap(
+    STCDPOpLx* op, transferInfo& dtEntry, const SliceInfo& inpSubPiece,
+    const SliceInfo& outSubPiece, const std::vector<int>& consumerMemIds) {
+  if (!op->enableSubStickRanges) return;
+  if (op->name != OpFuncs::STCDPOpLx) return;
+  DT_CHECK(inpSubPiece.placement.getMemId().size() == 1);
+  const int producerMemId = inpSubPiece.placement.getMemId().at(0);
+
+  for (const auto& dimAndSize : inpSubPiece.dimToSize_) {
+    const auto& dimName = dimAndSize.first;
+    if (outSubPiece.dimToSize_.count(dimName) == 0) continue;
+    const bool inpStickDim = op->inpLds->dimToStickSize_.count(dimName) != 0;
+    const bool outStickDim = op->outLds->dimToStickSize_.count(dimName) != 0;
+    if (!inpStickDim && !outStickDim) continue;
+
+    const int inpStickSize = inpStickDim ? op->inpLds->dimToStickSize_.at(dimName) : 1;
+    const int outStickSize = outStickDim ? op->outLds->dimToStickSize_.at(dimName) : 1;
+    const int inpSize = inpSubPiece.dimToSize_.at(dimName);
+    const int outSize = outSubPiece.dimToSize_.at(dimName);
+    if ((inpStickDim && inpSize >= inpStickSize) &&
+        (outStickDim && outSize >= outStickSize)) {
+      continue;
+    }
+
+    const int srcOffset = inpStickDim
+                              ? positiveRemainder(
+                                    inpSubPiece.dimToStartCordinate.at(dimName),
+                                    inpStickSize)
+                              : 0;
+    const int dstOffset = outStickDim
+                              ? positiveRemainder(
+                                    outSubPiece.dimToStartCordinate.at(dimName),
+                                    outStickSize)
+                              : 0;
+    const int elementCount = inpSize;
+    if (inpStickDim) {
+      DT_CHECK_MSG(srcOffset + elementCount <= inpStickSize,
+                   "Sub-stick source overlap crosses a layout stick.");
+    }
+    if (outStickDim) {
+      DT_CHECK_MSG(dstOffset + outSize <= outStickSize,
+                   "Sub-stick destination overlap crosses a layout stick.");
+    }
+
+    for (const int consumerMemId : consumerMemIds) {
+      SubStickRangeInfo range;
+      range.transferDim = dimName;
+      range.srcIntraStickOffset = srcOffset;
+      range.dstIntraStickOffset = dstOffset;
+      range.elementCount = elementCount;
+      range.producerMemId = producerMemId;
+      range.consumerMemId = consumerMemId;
+      dtEntry.subStickRanges.push_back(range);
+    }
+  }
+}
+
+static bool hasSubStickRanges(const baseSTCDPOp* op,
+                              const std::vector<int>& dtKeys) {
+  if (op->name != OpFuncs::STCDPOpLx) return false;
+  const auto* stcdpOp = static_cast<const STCDPOpLx*>(op);
+  if (!stcdpOp->enableSubStickRanges) return false;
+  for (const int dtKey : dtKeys) {
+    DT_CHECK(op->dtTable_.count(dtKey));
+    if (!op->dtTable_.at(dtKey).subStickRanges.empty()) return true;
+  }
+  return false;
+}
+
+static std::vector<SubStickRangeInfo> collectLocalSubStickRangesForRingDt(
+    const baseSTCDPOp* op, const std::vector<int>& dtKeys, int coreID,
+    SenComponents pcfgType) {
+  std::vector<SubStickRangeInfo> ranges;
+  if (!hasSubStickRanges(op, dtKeys)) return ranges;
+  DT_CHECK(pcfgType == SenComponents::L3SU ||
+           pcfgType == SenComponents::L3LU);
+
+  std::set<std::tuple<std::string, int, int, int, int, int>> seen;
+  for (const int dtKey : dtKeys) {
+    const auto& dtEntry = op->dtTable_.at(dtKey);
+    for (const auto& range : dtEntry.subStickRanges) {
+      const bool matchesCore =
+          pcfgType == SenComponents::L3SU
+              ? range.producerMemId == coreID
+              : range.consumerMemId == coreID;
+      if (!matchesCore) continue;
+      auto key = std::make_tuple(range.transferDim, range.srcIntraStickOffset,
+                                 range.dstIntraStickOffset, range.elementCount,
+                                 range.producerMemId, range.consumerMemId);
+      if (!seen.insert(key).second) continue;
+      ranges.push_back(range);
+    }
+  }
+  return ranges;
+}
+
+static void cloneAddrCondAndVal(
+    std::vector<std::pair<PcfgLccrCond, FoldManager<int64_t>>>& dst,
+    const std::vector<std::pair<PcfgLccrCond, FoldManager<int64_t>>>& src) {
+  dst.clear();
+  dst.resize(src.size());
+  for (int idx = 0; idx < src.size(); idx++) {
+    dst.at(idx).first = src.at(idx).first;
+    dst.at(idx).second.clone(src.at(idx).second);
+  }
+}
+
+static void cloneAnchorAddrToLocalLe128Node(
+    SenPcfgLE128BTransferNode* node, const SenPcfgRingDtNode* ringNode,
+    bool useRingSource) {
+  const auto& anchorAddr =
+      useRingSource ? ringNode->SrcStartAddr() : ringNode->DestStartAddr();
+  node->SrcStartAddr().clone(anchorAddr);
+  node->DestStartAddr().clone(anchorAddr);
+
+  const auto& anchorCondAndVal = useRingSource
+                                     ? ringNode->SrcStartCondAndVal()
+                                     : ringNode->DestStartCondAndVal();
+  cloneAddrCondAndVal(node->SrcStartCondAndVal(), anchorCondAndVal);
+  cloneAddrCondAndVal(node->DestStartCondAndVal(), anchorCondAndVal);
+}
+
+static SenPcfgLE128BTransferNode* createLocalSubStickLe128NodeForRingDt(
+    SenPcfg& pcfg, const baseSTCDPOp* op, const std::vector<int>& dtKeys,
+    int coreID, SenComponents pcfgType, int outerLoopIdx,
+    const SenPcfgRingDtNode* ringNode) {
+  auto ranges =
+      collectLocalSubStickRangesForRingDt(op, dtKeys, coreID, pcfgType);
+  if (ranges.empty()) return nullptr;
+
+  DT_CHECK(op->name == OpFuncs::STCDPOpLx);
+  const LdsInfo* lds =
+      pcfgType == SenComponents::L3SU ? op->inpLds : op->outLds;
+  DT_CHECK(lds != nullptr);
+  DT_CHECK(lds->wordLength > 0);
+  const int wordLength = static_cast<int>(lds->wordLength);
+  DT_CHECK(wordLength == lds->wordLength);
+
+  const std::string transferDim = ranges.front().transferDim;
+  DT_CHECK_MSG(lds->dimToStickSize_.count(transferDim) != 0,
+               "Sub-stick local LE128 lowering requires a stick dimension.");
+  const int stickSize = lds->dimToStickSize_.at(transferDim);
+
+  for (const auto& range : ranges) {
+    DT_CHECK_MSG(range.transferDim == transferDim,
+                 "Sub-stick local LE128 prototype only supports one transfer "
+                 "dimension per ring-DT node.");
+    DT_CHECK(range.elementCount > 0);
+    DT_CHECK(range.srcIntraStickOffset >= 0);
+    DT_CHECK(range.dstIntraStickOffset >= 0);
+    DT_CHECK(range.srcIntraStickOffset + range.elementCount <= stickSize);
+    DT_CHECK(range.dstIntraStickOffset + range.elementCount <= stickSize);
+  }
+
+  std::vector<SubStickRangeInfo> materializedRanges;
+  for (const auto& range : ranges) {
+    // The local helper is anchored to one LX address on both sides. Equal
+    // intra-stick offsets are already in place, so emitting an L3 load/store
+    // chain only bloats Agen lowering.
+    if (range.srcIntraStickOffset == range.dstIntraStickOffset) continue;
+    materializedRanges.push_back(range);
+  }
+  if (materializedRanges.empty()) return nullptr;
+
+  auto* localNode = static_cast<SenPcfgLE128BTransferNode*>(
+      pcfg.createPcfgNode(SenPcfgNode::Type::LE128BTRANSFER));
+  const std::string phase =
+      pcfgType == SenComponents::L3SU ? "localAssembleBeforeRing"
+                                      : "localExtractAfterRing";
+  localNode->name = "c" + std::to_string(coreID) + "-" +
+                    pcfg.senComponentsToString.at(pcfgType) + "-" + phase +
+                    "-" + std::to_string(outerLoopIdx) + "-" +
+                    std::to_string(op->uniqueID);
+  localNode->coreletId = -1;
+  localNode->dtInfo = nullptr;
+  localNode->dsInfo = nullptr;
+  localNode->srcDest = {SenComponents::LX, SenComponents::LX};
+  localNode->dimLayoutOrder = ringNode->dimLayoutOrder;
+  localNode->myBigDimSize = ringNode->myBigDimSize;
+  localNode->myLitDimSize = ringNode->myLitDimSize;
+  localNode->bigStAddrOffsets = ringNode->bigStAddrOffsets;
+  localNode->isPartStick = true;
+  localNode->useBurst = false;
+  localNode->wordLength = wordLength;
+  localNode->stickSize = stickSize;
+  cloneAnchorAddrToLocalLe128Node(
+      localNode, ringNode, pcfgType == SenComponents::L3SU);
+
+  for (const auto& range : materializedRanges) {
+    const int srcByteOffset = range.srcIntraStickOffset * wordLength;
+    const int dstByteOffset = range.dstIntraStickOffset * wordLength;
+    const int bytes = range.elementCount * wordLength;
+    localNode->byteOffsetTr.emplace_back(bytes, srcByteOffset, dstByteOffset,
+                                         true, true);
+  }
+  return localNode;
+}
+
+static void appendPcfgNode(SenPcfgNode*& lastTopNodeInner,
+                           SenPcfgNode* node) {
+  DT_CHECK(lastTopNodeInner != nullptr);
+  DT_CHECK(node != nullptr);
+  lastTopNodeInner->next.push_back(node);
+  node->prev.push_back(lastTopNodeInner);
+  lastTopNodeInner = node;
+}
+
+static void disableRingDtBurstForLocalSubStick(SenPcfgRingDtNode* ringNode) {
+  DT_CHECK(ringNode != nullptr);
+  // Local LE128 nodes share this loop, so the pure-ring burst rewrite is not
+  // legal for these staged sub-stick ring transfers.
+  ringNode->useBurst = false;
+  for (auto& condAndVal : ringNode->GTRAndBurstCondAndVal)
+    condAndVal.second.useBurst = false;
+}
+
+static void checkRingDtCanConsumeSubStickRanges(
+    const baseSTCDPOp* op, const std::vector<int>& dtKeys, int coreID,
+    SenComponents pcfgType) {
+  if (!hasSubStickRanges(op, dtKeys)) return;
+  auto ranges =
+      collectLocalSubStickRangesForRingDt(op, dtKeys, coreID, pcfgType);
+  DT_CHECK_MSG(!ranges.empty(),
+               "DXP_STCDP_SUBSTICK_RANGES reached ring-DT lowering, but no "
+               "local range matched this core/unit.");
+}
