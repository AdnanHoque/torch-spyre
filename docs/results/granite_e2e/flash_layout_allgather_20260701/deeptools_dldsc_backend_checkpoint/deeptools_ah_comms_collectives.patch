+
+#ifndef UTIL_LAYOUT_ALLGATHER_RESTICKIFY_H_
+#define UTIL_LAYOUT_ALLGATHER_RESTICKIFY_H_
+
+#include <cstdint>
+#include <map>
+#include <string>
+#include <vector>
+
+namespace deeptools {
+
+struct LayoutAllgatherRestickifyCheckResult {
+  bool ok = false;
+  std::string kind;
+  std::string communicationClass;
+  bool requiresStagedRealization = false;
+  std::string reason;
+  std::uint64_t sourceCoreCount = 0;
+  std::uint64_t restickifyCoreCount = 0;
+  std::uint64_t consumerCoreCount = 0;
+};
+
+struct LayoutAllgatherRestickifyMovementPlan {
+  bool ok = false;
+  std::string reason;
+  std::string communicationClass;
+  std::string movementPattern;
+  std::string restickifyOp;
+  std::string consumerOperandDsType;
+  std::uint64_t sourceCoreCount = 0;
+  std::uint64_t restickifyCoreCount = 0;
+  std::uint64_t consumerCoreCount = 0;
+  std::uint64_t groupCount = 0;
+  std::uint64_t producerChunksPerGroup = 0;
+  std::uint64_t consumerCoresPerGroup = 0;
+  std::uint64_t replicationFactor = 0;
+  std::uint64_t logicalTransferCount = 0;
+  std::vector<std::string> stages;
+};
+
+// Validate the explicit DLDSC-side contract for flash attention edges where a
+// producer layout must be restickified on chip and then gathered into the
+// consumer kernel operand. This is intentionally fail-closed: partial metadata
+// must not silently look like a realizable movement primitive.
+LayoutAllgatherRestickifyCheckResult checkLayoutAllgatherRestickifyContract(
+    const std::string &jsonString);
+
+// Consume a validated flash contract into a backend-facing movement plan. This
+// is intentionally narrower than the checker: only the known flash
+// mul->ReStickifyOpHBM->batchmatmul KERNEL edge is accepted.
+LayoutAllgatherRestickifyMovementPlan
+synthesizeLayoutAllgatherRestickifyMovementPlan(const std::string &jsonString);
+
+// Same as above, but accepts the flat string metadata preserved on SuperDsc.
+// Nested values are expected to be JSON-encoded strings.
+LayoutAllgatherRestickifyMovementPlan
+synthesizeLayoutAllgatherRestickifyMovementPlan(
+    const std::map<std::string, std::string> &fields);
+
+// Build the deterministic backend artifact emitted when DXP reaches the exact
+// mutation point but physical grouped lowering is not implemented yet.
+std::string layoutAllgatherRestickifyMovementPlanArtifactJson(
+    const LayoutAllgatherRestickifyMovementPlan &plan,
+    const std::map<std::string, std::string> &context);
+
+}  // namespace deeptools
+
+#endif  // UTIL_LAYOUT_ALLGATHER_RESTICKIFY_H_
