+static void emitLayoutAllgatherRestickifyPlanArtifact(
+    const SuperDsc* sdsc, const LabeledDsInfo& lds, int ps,
+    const LayoutAllgatherRestickifyHookPlan& hook) {
+  const auto& plan = hook.plan;
+  const char* outputDirEnv =
+      std::getenv("DEEPTOOLS_LAYOUT_ALLGATHER_RESTICKIFY_PLAN_DIR");
+  const std::filesystem::path outputDir =
+      outputDirEnv == nullptr ? std::filesystem::path(".")
+                              : std::filesystem::path(outputDirEnv);
+  std::filesystem::create_directories(outputDir);
+
+  const std::string fileName = sanitizeArtifactName(
+      sdsc->name_ + "_" + lds.dsName_ + "_" + hook.classificationKey +
+      "_layout_allgather_restickify_plan.json");
+  const auto outputPath = outputDir / fileName;
+
+  const std::map<std::string, std::string> context = {
+      {"schema_version", "1"},
+      {"mutation_point",
+       "Dxp::insertRelayoutSdsc after LX pinned input coordinate mismatch"},
+      {"realized", "false"},
+      {"reason",
+       "grouped STCDPOpLx lowering and batchmatmul KERNEL LX operand binding "
