+#include <gtest/gtest.h>
+
+#include <map>
+#include <string>
+
+#include "util/LayoutAllgatherRestickify.h"
+
+#include <external/json11/json11.hpp>
+
+namespace {
+
+std::string validFlashContract() {
+  return R"json({
+    "kind": "layout_allgather_restickify",
+    "communication_class": "all_gather",
+    "communication_pattern": "layout_allgather_restickify",
+    "producer_op": "mul",
+    "restickify_op": "ReStickifyOpHBM",
+    "consumer_op": "batchmatmul",
+    "requires_staged_realization": true,
+    "producer_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+    "restickify_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+    "consumer_work_slice_dims": {"x": 4, "mb": 8, "out": 1, "in": 1},
+    "producer_layout": {
+      "layoutDimOrder_": ["out", "x", "mb"],
+      "stickDimOrder_": ["out"]
+    },
+    "restickify_kernel_layout": {
+      "layoutDimOrder_": ["x", "out", "mb"],
+      "stickDimOrder_": ["x"]
+    },
+    "consumer_kernel_layout": {
+      "layoutDimOrder_": ["out", "in", "x"],
+      "stickDimOrder_": ["out"]
+    },
+    "dimension_rename": {
+      "restickify.mb": "batchmatmul.x",
+      "restickify.out": "batchmatmul.in",
+      "restickify.x": "batchmatmul.out"
+    },
+    "realized": false
+  })json";
+}
+
+std::string replaceFirst(std::string value, const std::string &from,
+                         const std::string &to) {
+  const auto pos = value.find(from);
+  if (pos == std::string::npos) return value;
+  value.replace(pos, from.size(), to);
+  return value;
+}
+
+}  // namespace
+
+TEST(LayoutAllgatherRestickify, acceptsCompleteFlashContract) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      validFlashContract());
+
+  EXPECT_TRUE(result.ok) << result.reason;
+  EXPECT_EQ(result.kind, "layout_allgather_restickify");
+  EXPECT_EQ(result.communicationClass, "all_gather");
+  EXPECT_TRUE(result.requiresStagedRealization);
+  EXPECT_EQ(result.sourceCoreCount, 32);
+  EXPECT_EQ(result.restickifyCoreCount, 32);
+  EXPECT_EQ(result.consumerCoreCount, 32);
+}
+
+TEST(LayoutAllgatherRestickify, rejectsScatterMetadata) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      R"json({
+        "kind": "layout_allgather_restickify",
+        "communication_class": "scatter",
+        "requires_staged_realization": true,
+        "producer_op": "mul",
+        "restickify_op": "ReStickifyOpHBM",
+        "consumer_op": "batchmatmul"
+      })json");
+
+  EXPECT_FALSE(result.ok);
+  EXPECT_EQ(result.reason, "communication_class must be all_gather");
+}
+
+TEST(LayoutAllgatherRestickify, rejectsMissingLayoutRename) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      R"json({
+        "kind": "layout_allgather_restickify",
+        "communication_class": "all_gather",
+        "requires_staged_realization": true,
+        "producer_op": "mul",
+        "restickify_op": "ReStickifyOpHBM",
+        "consumer_op": "batchmatmul",
+        "producer_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+        "restickify_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+        "consumer_work_slice_dims": {"x": 4, "mb": 8, "out": 1, "in": 1},
+        "producer_layout": {"layoutDimOrder_": ["out", "x", "mb"], "stickDimOrder_": ["out"]},
+        "restickify_kernel_layout": {"layoutDimOrder_": ["x", "out", "mb"], "stickDimOrder_": ["x"]},
+        "consumer_kernel_layout": {"layoutDimOrder_": ["out", "in", "x"], "stickDimOrder_": ["out"]}
+      })json");
+
+  EXPECT_FALSE(result.ok);
+  EXPECT_EQ(result.reason, "missing dimension_rename");
+}
+
+TEST(LayoutAllgatherRestickify, rejectsZeroWidthSplit) {
+  const auto result = deeptools::checkLayoutAllgatherRestickifyContract(
+      R"json({
+        "kind": "layout_allgather_restickify",
+        "communication_class": "all_gather",
+        "requires_staged_realization": true,
+        "producer_op": "mul",
+        "restickify_op": "ReStickifyOpHBM",
+        "consumer_op": "batchmatmul",
+        "producer_work_slice_dims": {"mb": 4, "x": 0, "out": 1},
+        "restickify_work_slice_dims": {"mb": 4, "x": 8, "out": 1},
+        "consumer_work_slice_dims": {"x": 4, "mb": 8, "out": 1, "in": 1},
+        "producer_layout": {"layoutDimOrder_": ["out", "x", "mb"], "stickDimOrder_": ["out"]},
+        "restickify_kernel_layout": {"layoutDimOrder_": ["x", "out", "mb"], "stickDimOrder_": ["x"]},
+        "consumer_kernel_layout": {"layoutDimOrder_": ["out", "in", "x"], "stickDimOrder_": ["out"]},
+        "dimension_rename": {"restickify.mb": "batchmatmul.x"}
+      })json");
+
+  EXPECT_FALSE(result.ok);
+  EXPECT_EQ(result.reason, "producer_work_slice_dims product must be non-zero");
+}
+
+TEST(LayoutAllgatherRestickify, synthesizesFlashMovementPlan) {
+  const auto plan = deeptools::synthesizeLayoutAllgatherRestickifyMovementPlan(
+      validFlashContract());
+
+  EXPECT_TRUE(plan.ok) << plan.reason;
+  EXPECT_EQ(plan.communicationClass, "all_gather");
+  EXPECT_EQ(plan.movementPattern, "layout_allgather_restickify");
+  EXPECT_EQ(plan.restickifyOp, "ReStickifyOpLx");
+  EXPECT_EQ(plan.consumerOperandDsType, "KERNEL");
+  EXPECT_EQ(plan.sourceCoreCount, 32);
+  EXPECT_EQ(plan.restickifyCoreCount, 32);
+  EXPECT_EQ(plan.consumerCoreCount, 32);
+  EXPECT_EQ(plan.groupCount, 4);
+  EXPECT_EQ(plan.producerChunksPerGroup, 8);
+  EXPECT_EQ(plan.consumerCoresPerGroup, 8);
+  EXPECT_EQ(plan.replicationFactor, 8);
+  EXPECT_EQ(plan.logicalTransferCount, 256);
+  ASSERT_EQ(plan.stages.size(), 3);
+  EXPECT_EQ(plan.stages[0], "restickify_layout_on_chip");
+  EXPECT_EQ(plan.stages[1], "grouped_all_gather");
+  EXPECT_EQ(plan.stages[2], "bind_bmm_kernel_operand");
+}
+
+TEST(LayoutAllgatherRestickify, synthesizesFlashMovementPlanFromLxRestickify) {
+  const auto contract = replaceFirst(
+      validFlashContract(), R"json("restickify_op": "ReStickifyOpHBM")json",
+      R"json("restickify_op": "ReStickifyOpLx")json");
+
+  const auto plan =
+      deeptools::synthesizeLayoutAllgatherRestickifyMovementPlan(contract);
+
+  EXPECT_TRUE(plan.ok) << plan.reason;
+  EXPECT_EQ(plan.restickifyOp, "ReStickifyOpLx");
+  EXPECT_EQ(plan.logicalTransferCount, 256);
+}
+
+TEST(LayoutAllgatherRestickify,
+     synthesizesFlashMovementPlanFromSuperDscMetadata) {
+  const std::map<std::string, std::string> fields = {
+      {"kind", "layout_allgather_restickify"},
+      {"communication_class", "all_gather"},
+      {"communication_pattern", "layout_allgather_restickify"},
+      {"producer_op", "mul"},
+      {"restickify_op", "ReStickifyOpHBM"},
+      {"consumer_op", "batchmatmul"},
+      {"requires_staged_realization", "true"},
+      {"producer_work_slice_dims", R"json({"mb":4,"x":8,"out":1})json"},
+      {"restickify_work_slice_dims", R"json({"mb":4,"x":8,"out":1})json"},
+      {"consumer_work_slice_dims", R"json({"x":4,"mb":8,"out":1,"in":1})json"},
+      {"producer_layout", R"json({"layoutDimOrder_":["out","x","mb"],"stickDimOrder_":["out"]})json"},
+      {"restickify_kernel_layout", R"json({"layoutDimOrder_":["x","out","mb"],"stickDimOrder_":["x"]})json"},
+      {"consumer_kernel_layout", R"json({"layoutDimOrder_":["out","in","x"],"stickDimOrder_":["out"]})json"},
+      {"dimension_rename", R"json({"restickify.mb":"batchmatmul.x","restickify.out":"batchmatmul.in","restickify.x":"batchmatmul.out"})json"},
+  };
+
+  const auto plan =
+      deeptools::synthesizeLayoutAllgatherRestickifyMovementPlan(fields);
+
+  EXPECT_TRUE(plan.ok) << plan.reason;
+  EXPECT_EQ(plan.groupCount, 4);
+  EXPECT_EQ(plan.producerChunksPerGroup, 8);
+  EXPECT_EQ(plan.consumerCoresPerGroup, 8);
+  EXPECT_EQ(plan.logicalTransferCount, 256);
+}
+
+TEST(LayoutAllgatherRestickify, emitsDeterministicBackendPlanArtifact) {
+  const auto plan = deeptools::synthesizeLayoutAllgatherRestickifyMovementPlan(
+      validFlashContract());
+  ASSERT_TRUE(plan.ok) << plan.reason;
+
+  const auto artifactJson =
+      deeptools::layoutAllgatherRestickifyMovementPlanArtifactJson(
+          plan, {{"schema_version", "1"},
+                 {"mutation_point",
+                  "Dxp::insertRelayoutSdsc after LX pinned input coordinate "
+                  "mismatch"},
+                 {"realized", "false"},
+                 {"sdsc_name", "3_batchmatmul"},
+                 {"input_labeled_ds", "Tensor0"},
+                 {"classification_key", "buf9"},
+                 {"program_step", "3"}});
+
+  std::string err;
+  const auto artifact = json11::Json::parse(artifactJson, err);
+  ASSERT_TRUE(err.empty()) << err;
+  EXPECT_EQ(artifact["artifact_kind"].string_value(),
+            "layout_allgather_restickify_backend_plan");
+  EXPECT_FALSE(artifact["realized"].bool_value());
+  EXPECT_EQ(artifact["classification_key"].string_value(), "buf9");
+  EXPECT_EQ(artifact["group_count"].string_value(), "4");
+  EXPECT_EQ(artifact["producer_chunks_per_group"].string_value(), "8");
+  EXPECT_EQ(artifact["consumer_cores_per_group"].string_value(), "8");
+  EXPECT_EQ(artifact["logical_transfer_count"].string_value(), "256");
+  ASSERT_TRUE(artifact["stages"].is_array());
+  ASSERT_EQ(artifact["stages"].array_items().size(), 3);
+  EXPECT_EQ(artifact["stages"].array_items()[1].string_value(),
+            "grouped_all_gather");
+}
+
+TEST(LayoutAllgatherRestickify, movementPlanRejectsNonFlashProducer) {
+  const auto contract = replaceFirst(validFlashContract(),
+                                     R"json("producer_op": "mul")json",
