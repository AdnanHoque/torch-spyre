--- /dev/null
+++ b/util/LayoutAllgatherRestickify.cpp
@@ -0,0 +1,371 @@
+/************************************************************
+ * IBM Confidential
+ * (C) Copyright IBM Corp. 2026
+ ************************************************************/
+
+#include "util/LayoutAllgatherRestickify.h"
+
+#include <external/json11/json11.hpp>
+
+#include <cstdint>
+#include <map>
+#include <set>
+#include <string>
+#include <vector>
+
+namespace {
+
+using json11::Json;
+
+bool hasNonEmptyString(const Json &json, const std::string &key) {
+  return json[key].is_string() && !json[key].string_value().empty();
+}
+
+bool hasNonEmptyObject(const Json &json, const std::string &key) {
+  return json[key].is_object() && !json[key].object_items().empty();
+}
+
+bool hasNonEmptyArray(const Json &json, const std::string &key) {
+  return json[key].is_array() && !json[key].array_items().empty();
+}
+
+bool hasLayoutContract(const Json &json, const std::string &key) {
+  const Json &layout = json[key];
+  return layout.is_object() && hasNonEmptyArray(layout, "layoutDimOrder_") &&
+         hasNonEmptyArray(layout, "stickDimOrder_");
+}
+
+std::uint64_t splitProduct(const Json &dims) {
+  if (!dims.is_object()) return 0;
+
+  std::uint64_t product = 1;
+  bool sawDim = false;
+  for (const auto &[_, value] : dims.object_items()) {
+    const int dim = value.int_value();
+    if (dim <= 0) return 0;
+    product *= static_cast<std::uint64_t>(dim);
+    sawDim = true;
+  }
+  return sawDim ? product : 0;
+}
+
+std::uint64_t splitForDim(const Json &dims, const std::string &dim) {
+  if (!dims.is_object()) return 0;
+  const int split = dims[dim].int_value();
+  return split > 0 ? static_cast<std::uint64_t>(split) : 0;
+}
+
+std::vector<std::string> stringArray(const Json &json) {
+  std::vector<std::string> values;
+  if (!json.is_array()) return values;
+  for (const auto &value : json.array_items()) {
+    if (!value.is_string()) return {};
+    values.push_back(value.string_value());
+  }
+  return values;
+}
+
+bool optionalStringIs(const Json &json, const std::string &key,
+                      const std::string &expected) {
+  return json[key].is_null() ||
+         (json[key].is_string() && json[key].string_value() == expected);
+}
+
+bool isSupportedRestickifyOp(const std::string &op) {
+  return op == "ReStickifyOpHBM" || op == "ReStickifyOpLx";
+}
+
+Json metadataValueToJson(const std::string &value) {
+  if (value == "true") return Json(true);
+  if (value == "false") return Json(false);
+
+  const auto first = value.find_first_not_of(" \t\n\r");
+  if (first != std::string::npos &&
+      (value[first] == '{' || value[first] == '[')) {
+    std::string err;
+    const Json parsed = Json::parse(value, err);
+    if (err.empty()) return parsed;
+  }
+
+  return Json(value);
+}
+
+std::string metadataFieldsToJsonString(
+    const std::map<std::string, std::string> &fields) {
+  Json::object object;
+  for (const auto &[key, value] : fields) {
+    object[key] = metadataValueToJson(value);
+  }
+  return Json(object).dump();
+}
+
+bool allRestickifyDimsRenamedToConsumer(const Json &json,
+                                        std::string *reason) {
+  const auto restickifyDims = stringArray(
+      json["restickify_kernel_layout"]["layoutDimOrder_"]);
+  const auto consumerDims =
+      stringArray(json["consumer_kernel_layout"]["layoutDimOrder_"]);
+  if (restickifyDims.empty() || consumerDims.empty()) {
+    *reason = "missing restickify or consumer layout dimensions";
+    return false;
+  }
+
+  const std::set<std::string> consumerDimSet(consumerDims.begin(),
+                                             consumerDims.end());
+  const Json &rename = json["dimension_rename"];
+  if (!rename.is_object()) {
+    *reason = "missing dimension_rename";
+    return false;
+  }
+
+  for (const auto &dim : restickifyDims) {
+    const std::string renameKey = "restickify." + dim;
+    const Json &renamed = rename[renameKey];
+    if (!renamed.is_string() || renamed.string_value().empty()) {
+      *reason = "missing rename for " + renameKey;
+      return false;
+    }
+
+    const std::string consumerPrefix = "batchmatmul.";
+    const std::string renamedValue = renamed.string_value();
+    if (renamedValue.rfind(consumerPrefix, 0) != 0) {
+      *reason = renameKey + " must rename to a batchmatmul dimension";
+      return false;
+    }
+
+    const std::string consumerDim = renamedValue.substr(consumerPrefix.size());
+    if (consumerDimSet.count(consumerDim) == 0) {
+      *reason = renamedValue + " is not in consumer_kernel_layout";
+      return false;
+    }
+  }
+
+  return true;
+}
+
+deeptools::LayoutAllgatherRestickifyMovementPlan movementFail(
+    const std::string &reason) {
+  deeptools::LayoutAllgatherRestickifyMovementPlan plan;
+  plan.reason = reason;
+  return plan;
+}
+
+deeptools::LayoutAllgatherRestickifyCheckResult fail(
+    const std::string &reason) {
+  deeptools::LayoutAllgatherRestickifyCheckResult result;
+  result.reason = reason;
+  return result;
+}
+
+}  // namespace
+
+namespace deeptools {
+
+LayoutAllgatherRestickifyCheckResult checkLayoutAllgatherRestickifyContract(
+    const std::string &jsonString) {
+  std::string err;
+  const Json json = Json::parse(jsonString, err);
+  if (!err.empty()) {
+    return fail("invalid json: " + err);
+  }
+  if (!json.is_object()) {
+    return fail("contract must be a json object");
+  }
+
+  LayoutAllgatherRestickifyCheckResult result;
+  result.kind = json["kind"].string_value();
+  result.communicationClass = json["communication_class"].string_value();
+  result.requiresStagedRealization =
+      json["requires_staged_realization"].bool_value();
+
+  if (result.kind != "layout_allgather_restickify") {
+    return fail("kind must be layout_allgather_restickify");
+  }
+  if (result.communicationClass != "all_gather") {
+    return fail("communication_class must be all_gather");
+  }
+  if (!result.requiresStagedRealization) {
+    return fail("requires_staged_realization must be true");
+  }
+
+  if (!hasNonEmptyString(json, "producer_op")) {
+    return fail("missing producer_op");
+  }
+  if (!hasNonEmptyString(json, "restickify_op")) {
+    return fail("missing restickify_op");
+  }
+  if (!hasNonEmptyString(json, "consumer_op")) {
+    return fail("missing consumer_op");
+  }
+
+  if (!hasLayoutContract(json, "producer_layout")) {
+    return fail("missing producer_layout layout/stick dim order");
+  }
+  if (!hasLayoutContract(json, "restickify_kernel_layout")) {
+    return fail("missing restickify_kernel_layout layout/stick dim order");
+  }
+  if (!hasLayoutContract(json, "consumer_kernel_layout")) {
+    return fail("missing consumer_kernel_layout layout/stick dim order");
+  }
+  if (!hasNonEmptyObject(json, "dimension_rename")) {
+    return fail("missing dimension_rename");
+  }
+
+  if (!hasNonEmptyObject(json, "producer_work_slice_dims")) {
+    return fail("missing producer_work_slice_dims");
+  }
+  if (!hasNonEmptyObject(json, "restickify_work_slice_dims")) {
+    return fail("missing restickify_work_slice_dims");
+  }
+  if (!hasNonEmptyObject(json, "consumer_work_slice_dims")) {
+    return fail("missing consumer_work_slice_dims");
+  }
+
+  result.sourceCoreCount = splitProduct(json["producer_work_slice_dims"]);
+  result.restickifyCoreCount = splitProduct(json["restickify_work_slice_dims"]);
+  result.consumerCoreCount = splitProduct(json["consumer_work_slice_dims"]);
+  if (result.sourceCoreCount == 0) {
+    return fail("producer_work_slice_dims product must be non-zero");
+  }
+  if (result.restickifyCoreCount == 0) {
+    return fail("restickify_work_slice_dims product must be non-zero");
+  }
+  if (result.consumerCoreCount == 0) {
+    return fail("consumer_work_slice_dims product must be non-zero");
+  }
+
+  result.ok = true;
+  result.reason = "ok";
+  return result;
+}
+
+LayoutAllgatherRestickifyMovementPlan
+synthesizeLayoutAllgatherRestickifyMovementPlan(
+    const std::string &jsonString) {
+  const auto check = checkLayoutAllgatherRestickifyContract(jsonString);
+  if (!check.ok) {
+    return movementFail("contract check failed: " + check.reason);
+  }
+
+  std::string err;
+  const Json json = Json::parse(jsonString, err);
+  if (!err.empty() || !json.is_object()) {
+    return movementFail("invalid json after contract check");
+  }
+
+  if (!optionalStringIs(json, "communication_pattern",
+                        "layout_allgather_restickify")) {
+    return movementFail(
+        "communication_pattern must be layout_allgather_restickify");
+  }
+  if (json["producer_op"].string_value() != "mul") {
+    return movementFail("producer_op must be mul");
+  }
+  if (!isSupportedRestickifyOp(json["restickify_op"].string_value())) {
+    return movementFail("restickify_op must be ReStickifyOpHBM or ReStickifyOpLx");
+  }
+  if (json["consumer_op"].string_value() != "batchmatmul") {
+    return movementFail("consumer_op must be batchmatmul");
+  }
+  if (check.sourceCoreCount != check.restickifyCoreCount) {
+    return movementFail(
+        "producer/restickify core counts must match for on-chip restickify");
+  }
+
+  const Json &restickifySplits = json["restickify_work_slice_dims"];
+  const Json &consumerSplits = json["consumer_work_slice_dims"];
+  const std::uint64_t groupCount = splitForDim(restickifySplits, "mb");
+  const std::uint64_t consumerGroupCount = splitForDim(consumerSplits, "x");
+  const std::uint64_t producerChunksPerGroup =
+      splitForDim(restickifySplits, "x");
+  const std::uint64_t consumerCoresPerGroup = splitForDim(consumerSplits, "mb");
+  if (groupCount == 0 || consumerGroupCount == 0 ||
+      producerChunksPerGroup == 0 || consumerCoresPerGroup == 0) {
+    return movementFail(
+        "restickify mb/x and consumer x/mb splits must be non-zero");
+  }
+  if (groupCount != consumerGroupCount) {
+    return movementFail("restickify mb split must match batchmatmul x split");
+  }
+  if (check.restickifyCoreCount != groupCount * producerChunksPerGroup) {
+    return movementFail(
+        "restickify core count must equal mb groups times x chunks");
+  }
+  if (check.consumerCoreCount != groupCount * consumerCoresPerGroup) {
+    return movementFail(
+        "consumer core count must equal x groups times mb consumers");
+  }
+  if (splitForDim(consumerSplits, "out") != 1 ||
+      splitForDim(consumerSplits, "in") != 1) {
+    return movementFail("only unsplit batchmatmul out/in are supported");
+  }
+
+  std::string renameReason;
+  if (!allRestickifyDimsRenamedToConsumer(json, &renameReason)) {
+    return movementFail("dimension_rename cannot drive movement: " +
+                        renameReason);
+  }
+
+  LayoutAllgatherRestickifyMovementPlan plan;
+  plan.ok = true;
+  plan.reason = "ok";
+  plan.communicationClass = check.communicationClass;
+  plan.movementPattern = check.kind;
+  plan.restickifyOp = "ReStickifyOpLx";
+  plan.consumerOperandDsType = "KERNEL";
+  plan.sourceCoreCount = check.sourceCoreCount;
+  plan.restickifyCoreCount = check.restickifyCoreCount;
+  plan.consumerCoreCount = check.consumerCoreCount;
+  plan.groupCount = groupCount;
+  plan.producerChunksPerGroup = producerChunksPerGroup;
+  plan.consumerCoresPerGroup = consumerCoresPerGroup;
+  plan.replicationFactor = consumerCoresPerGroup;
+  plan.logicalTransferCount =
+      groupCount * producerChunksPerGroup * consumerCoresPerGroup;
+  plan.stages = {"restickify_layout_on_chip", "grouped_all_gather",
+                 "bind_bmm_kernel_operand"};
+  return plan;
+}
+
+LayoutAllgatherRestickifyMovementPlan
+synthesizeLayoutAllgatherRestickifyMovementPlan(
+    const std::map<std::string, std::string> &fields) {
+  return synthesizeLayoutAllgatherRestickifyMovementPlan(
+      metadataFieldsToJsonString(fields));
+}
+
+std::string layoutAllgatherRestickifyMovementPlanArtifactJson(
+    const LayoutAllgatherRestickifyMovementPlan &plan,
+    const std::map<std::string, std::string> &context) {
+  std::vector<Json> stages;
+  for (const auto &stage : plan.stages) stages.emplace_back(stage);
+
+  Json::object artifact;
+  artifact["artifact_kind"] = "layout_allgather_restickify_backend_plan";
+  for (const auto &[key, value] : context) {
+    artifact[key] = metadataValueToJson(value);
+  }
+  artifact["communication_class"] = plan.communicationClass;
+  artifact["movement_pattern"] = plan.movementPattern;
+  artifact["restickify_op"] = plan.restickifyOp;
+  artifact["consumer_operand_ds_type"] = plan.consumerOperandDsType;
+  artifact["source_core_count"] =
+      std::to_string(plan.sourceCoreCount);
+  artifact["restickify_core_count"] =
+      std::to_string(plan.restickifyCoreCount);
+  artifact["consumer_core_count"] =
+      std::to_string(plan.consumerCoreCount);
+  artifact["group_count"] = std::to_string(plan.groupCount);
+  artifact["producer_chunks_per_group"] =
+      std::to_string(plan.producerChunksPerGroup);
+  artifact["consumer_cores_per_group"] =
+      std::to_string(plan.consumerCoresPerGroup);
+  artifact["replication_factor"] =
+      std::to_string(plan.replicationFactor);
+  artifact["logical_transfer_count"] =
+      std::to_string(plan.logicalTransferCount);
+  artifact["stages"] = stages;
+  return Json(artifact).dump();
+}
+
+}  // namespace deeptools
