+
+static LayoutAllgatherRestickifyHookPlan findLayoutAllgatherRestickifyPlan(
+    const SuperDsc* sdsc) {
+  for (const auto& entry : sdsc->lxRelayoutClassifications_) {
+    const auto& fields = entry.second;
+    const auto kindIt = fields.find("kind");
+    const auto patternIt = fields.find("communication_pattern");
+    const bool isLayoutAllgather =
+        (kindIt != fields.end() &&
+         kindIt->second == "layout_allgather_restickify") ||
+        (patternIt != fields.end() &&
+         patternIt->second == "layout_allgather_restickify");
+    if (!isLayoutAllgather) continue;
+
+    return {entry.first,
+            deeptools::synthesizeLayoutAllgatherRestickifyMovementPlan(fields)};
+  }
+
+  return {};
+}
+
+static std::string sanitizeArtifactName(std::string value) {
+  for (char& ch : value) {
+    const auto c = static_cast<unsigned char>(ch);
+    if (!std::isalnum(c) && ch != '-' && ch != '_' && ch != '.') ch = '_';
+  }
+  return value;
+}
