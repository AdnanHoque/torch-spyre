+std::optional<int> getOptionalIntEnv(const std::string& name) {
+  const auto value = dtGetEnv<std::string>(name);
+  if (!value.has_value() || value->empty()) return std::nullopt;
+  return std::stoi(*value);
+}
+
+int64_t computeLayoutStickOffset(DesignSpaceConfig& dsc, PieceInfo& piece,
+                                 LabeledDsInfo& dlLds,
+                                 const std::string& mbDim,
+                                 const std::string& outDim, int localMb,
+                                 int localOutStick, int localMbExtent,
+                                 int localOutSticks) {
+  const auto primaryIt = dsc.primaryDsInfo_.find(dlLds.dsType_);
+  DT_CHECK(primaryIt != dsc.primaryDsInfo_.end());
+  const auto& layoutDimOrder = primaryIt->second.layoutDimOrder_;
+  int64_t stride = 1;
+  int64_t offset = 0;
+  bool sawMb = false;
+  bool sawOut = false;
+  for (const auto& dim : layoutDimOrder) {
+    int coord = 0;
+    int extent = 1;
+    if (dim == PrimaryDimTypes::MB) {
+      coord = localMb;
+      extent = localMbExtent;
+      sawMb = true;
+    } else if (dim == PrimaryDimTypes::OUT) {
+      coord = localOutStick;
+      extent = localOutSticks;
+      sawOut = true;
+    } else {
+      const std::string dimName = EnumsConversion::primaryDimToString.at(dim);
+      extent = getCoreExtent(dsc, dimName);
+      DT_CHECK(extent == 1);
+      coord = 0;
+    }
+    DT_CHECK(coord >= 0);
+    DT_CHECK(coord < extent);
+    offset += static_cast<int64_t>(coord) * stride;
+    stride *= extent;
+  }
+  DT_CHECK(sawMb);
+  DT_CHECK(sawOut);
+  return offset;
+}
+
+bool layoutHasDimBefore(DesignSpaceConfig& dsc, LabeledDsInfo& dlLds,
+                        PrimaryDimTypes lhs, PrimaryDimTypes rhs) {
+  const auto primaryIt = dsc.primaryDsInfo_.find(dlLds.dsType_);
+  DT_CHECK(primaryIt != dsc.primaryDsInfo_.end());
+  const auto& layoutDimOrder = primaryIt->second.layoutDimOrder_;
+  auto lhsIt = std::find(layoutDimOrder.begin(), layoutDimOrder.end(), lhs);
+  auto rhsIt = std::find(layoutDimOrder.begin(), layoutDimOrder.end(), rhs);
+  DT_CHECK(lhsIt != layoutDimOrder.end());
+  DT_CHECK(rhsIt != layoutDimOrder.end());
+  return lhsIt < rhsIt;
+}
