+bool hasPieceDim(const PieceInfo& piece, const std::string& dimName) {
+  return piece.dimToStartCordinate.count(dimName) &&
+         piece.dimToSize_.count(dimName);
+}
+
+std::string selectPieceDim(const PieceInfo& piece,
+                           const std::string& logicalDim,
+                           const std::string& legacyDim) {
+  if (hasPieceDim(piece, logicalDim)) return logicalDim;
+  DT_CHECK(hasPieceDim(piece, legacyDim));
+  return legacyDim;
+}
+
+int getStickElems(const PieceInfo& piece, LdsInfo& dataLds,
+                  const std::string& outDim) {
+  if (dataLds.dimToStickSize_.count(outDim)) {
+    return static_cast<int>(dataLds.dimToStickSize_.at(outDim));
+  }
+  if (hasPieceDim(piece, "d3_")) return getPieceInt(piece, "d3_", true);
+  return getPieceInt(piece, outDim, true);
+}
