@@ -12,6 +12,157 @@
 
 #include "util/dt_exception.hpp"
 
+namespace {
+
+int64_t getJsonI64(const json11::Json& obj, const std::string& key) {
+  DT_CHECK_MSG(obj[key].is_number(),
+               "STCDPOpLx ranged remap missing numeric field: " + key);
+  return static_cast<int64_t>(obj[key].number_value());
+}
+
+std::string getJsonString(const json11::Json& obj, const std::string& key) {
+  DT_CHECK_MSG(obj[key].is_string(),
+               "STCDPOpLx ranged remap missing string field: " + key);
+  return obj[key].string_value();
+}
+
+std::pair<int64_t, int64_t> getByteRange(const json11::Json& obj,
+                                         const std::string& key) {
+  DT_CHECK_MSG(obj[key].is_object(),
+               "STCDPOpLx ranged remap missing range field: " + key);
+  return {getJsonI64(obj[key], "start"), getJsonI64(obj[key], "end")};
+}
+
+STCDPOpLx::RangeMovementSide parseMovementSide(const json11::Json& obj,
+                                               const std::string& key,
+                                               int64_t expectedBytes) {
+  DT_CHECK_MSG(obj[key].is_object(),
+               "STCDPOpLx ranged remap missing side field: " + key);
+  const auto& sideJson = obj[key];
+  STCDPOpLx::RangeMovementSide side;
+  side.core = static_cast<int>(getJsonI64(sideJson, "core"));
+  side.lxAddress = getJsonI64(sideJson, "lxAddress");
+
+  auto localRange = getByteRange(sideJson, "localByteRange");
+  side.localStart = localRange.first;
+  side.localEnd = localRange.second;
+
+  auto lxRange = getByteRange(sideJson, "lxByteRange");
+  side.lxStart = lxRange.first;
+  side.lxEnd = lxRange.second;
+
+  DT_CHECK_MSG(side.core >= 0,
+               "STCDPOpLx ranged remap side has negative core id");
+  DT_CHECK_MSG(side.localEnd >= side.localStart,
+               "STCDPOpLx ranged remap side has invalid local byte range");
+  DT_CHECK_MSG(side.lxEnd >= side.lxStart,
+               "STCDPOpLx ranged remap side has invalid LX byte range");
+  DT_CHECK_MSG(side.localEnd - side.localStart == expectedBytes,
+               "STCDPOpLx ranged remap side local range does not match bytes");
+  DT_CHECK_MSG(side.lxEnd - side.lxStart == expectedBytes,
+               "STCDPOpLx ranged remap side LX range does not match bytes");
+  DT_CHECK_MSG(side.lxAddress == side.lxStart,
+               "STCDPOpLx ranged remap lxAddress must match lxByteRange.start");
+  return side;
+}
+
+STCDPOpLx::RangeMovement parseMovement(const json11::Json& moveJson) {
+  STCDPOpLx::RangeMovement move;
+  move.moveIndex = static_cast<int>(getJsonI64(moveJson, "moveIndex"));
+  move.bytes = getJsonI64(moveJson, "bytes");
+  DT_CHECK_MSG(move.bytes > 0,
+               "STCDPOpLx ranged remap movement has non-positive byte count");
+  move.source = parseMovementSide(moveJson, "source", move.bytes);
+  move.destination = parseMovementSide(moveJson, "destination", move.bytes);
+  return move;
+}
+
+void addByteOffset(STCDPOpLx::RangeMovementSide& side, int64_t byteOffset) {
+  side.lxAddress += byteOffset;
+  side.localStart += byteOffset;
+  side.localEnd += byteOffset;
+  side.lxStart += byteOffset;
+  side.lxEnd += byteOffset;
+}
+
+STCDPOpLx::RangeMovementRange parseMovementRange(
+    const json11::Json& rangeJson) {
+  DT_CHECK_MSG(rangeJson.is_object(),
+               "STCDPOpLx ranged remap movementRanges entries must be objects");
+  STCDPOpLx::RangeMovementRange range;
+  range.rangeIndex = static_cast<int>(getJsonI64(rangeJson, "rangeIndex"));
+  range.moveIndex = static_cast<int>(getJsonI64(rangeJson, "moveIndex"));
+  range.count = getJsonI64(rangeJson, "count");
+  range.bytesPerMove = getJsonI64(rangeJson, "bytesPerMove");
+  range.sourceStrideBytes = getJsonI64(rangeJson, "sourceStrideBytes");
+  range.destinationStrideBytes =
+      getJsonI64(rangeJson, "destinationStrideBytes");
+  DT_CHECK_MSG(range.count > 0,
+               "STCDPOpLx ranged remap movement range has non-positive count");
+  DT_CHECK_MSG(range.bytesPerMove > 0,
+               "STCDPOpLx ranged remap movement range has non-positive byte count");
+  DT_CHECK_MSG(range.count == 1 || range.sourceStrideBytes >= 0,
+               "STCDPOpLx ranged remap movement range has negative source stride");
+  DT_CHECK_MSG(range.count == 1 || range.destinationStrideBytes >= 0,
+               "STCDPOpLx ranged remap movement range has negative destination stride");
+  range.source = parseMovementSide(rangeJson, "source", range.bytesPerMove);
+  range.destination =
+      parseMovementSide(rangeJson, "destination", range.bytesPerMove);
+  return range;
+}
+
+void expandMovementRange(const STCDPOpLx::RangeMovementRange& range,
+                         std::vector<STCDPOpLx::RangeMovement>& movements) {
+  for (int64_t offset = 0; offset < range.count; ++offset) {
+    STCDPOpLx::RangeMovement move;
+    move.moveIndex = range.moveIndex + static_cast<int>(offset);
+    move.bytes = range.bytesPerMove;
+    move.source = range.source;
+    move.destination = range.destination;
+    addByteOffset(move.source, offset * range.sourceStrideBytes);
+    addByteOffset(move.destination, offset * range.destinationStrideBytes);
+    movements.push_back(move);
+  }
+}
+
+void parseStcdpLxRangeRemapPayload(const json11::Json& dscJson,
+                                   STCDPOpLx* op) {
+  op->rangeModeEnabled = true;
+  op->rangeSchemaVersion = static_cast<int>(getJsonI64(dscJson, "schemaVersion"));
+  op->rangeSourceName = getJsonString(dscJson, "sourceName");
+  op->rangeProducer = getJsonString(dscJson, "producer");
+  op->rangeConsumer = getJsonString(dscJson, "consumer");
+  op->rangeProducerLxBase = getJsonI64(dscJson, "producerLxBase");
+  op->rangeConsumerLxBase = getJsonI64(dscJson, "consumerLxBase");
+
+  const bool hasMovements = dscJson["movements"].is_array();
+  const bool hasMovementRanges = dscJson["movementRanges"].is_array();
+  DT_CHECK_MSG(hasMovements || hasMovementRanges,
+               "STCDPOpLx ranged remap requires movements or movementRanges array");
+
+  op->rangeMovements.clear();
+  op->rangeMovementRanges.clear();
+  if (hasMovements) {
+    for (const auto& moveJson : dscJson["movements"].array_items()) {
+      op->rangeMovements.push_back(parseMovement(moveJson));
+    }
+  }
+  const bool needsRangeExpansion = op->rangeMovements.empty();
+  if (hasMovementRanges) {
+    for (const auto& rangeJson : dscJson["movementRanges"].array_items()) {
+      auto range = parseMovementRange(rangeJson);
+      op->rangeMovementRanges.push_back(range);
+      if (needsRangeExpansion) {
+        expandMovementRange(range, op->rangeMovements);
+      }
+    }
+  }
+  DT_CHECK_MSG(!op->rangeMovements.empty() || !op->rangeMovementRanges.empty(),
+               "STCDPOpLx ranged remap has no movements after import");
+}
+
